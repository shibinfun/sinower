<div class="max-w-screen-xl mx-auto px-4 py-8">
  <!-- 顶部面包屑导航 (取代分类树) -->
  <div class="mb-10 sticky top-20 z-10">
    <nav class="flex items-center overflow-x-auto whitespace-nowrap py-4 px-6 bg-white/80 backdrop-blur-md rounded-2xl border border-slate-200/50 shadow-sm transition-all duration-300">
      <div class="flex items-center space-x-2 text-sm font-bold">
        <%= link_to (@kind ? send("#{@kind}_channel_path") : categories_path), class: "flex items-center text-slate-400 hover:text-blue-600 transition-all group" do %>
          <span class="p-1.5 rounded-lg bg-slate-100 group-hover:bg-blue-50 transition-colors mr-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
          </span>
          <span class="tracking-tight uppercase text-[10px]">全部产品</span>
        <% end %>
        
        <% if @current_category %>
          <% @current_category.ancestors_and_self.each do |cat| %>
            <div class="flex items-center space-x-2">
              <svg class="w-4 h-4 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              <%= link_to (@kind ? send("#{@kind}_channel_path", category_id: cat.id) : categories_path(category_id: cat.id)), class: "px-3 py-1.5 rounded-xl transition-all #{cat == @current_category ? 'bg-blue-600 text-white shadow-lg shadow-blue-500/30' : 'text-slate-500 hover:bg-slate-100 hover:text-slate-900'}" do %>
                <span class="text-xs tracking-wide"><%= cat.name %></span>
              <% end %>
            </div>
          <% end %>
        <% end %>

        <!-- 动态展示下一级分类 -->
        <div class="flex items-center space-x-2 border-l border-slate-200 ml-4 pl-4">
          <svg class="w-4 h-4 text-slate-300 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
          <div class="flex items-center space-x-2">
            <% if @current_category && @current_category.children.any? %>
              <% @current_category.children.each do |child| %>
                <%= link_to (@kind ? send("#{@kind}_channel_path", category_id: child.id) : categories_path(category_id: child.id)), class: "px-3 py-1.5 bg-slate-50 border border-slate-100 rounded-xl text-[11px] font-bold text-slate-600 hover:border-blue-400 hover:text-blue-600 hover:bg-white hover:shadow-sm transition-all" do %>
                  <%= child.name %>
                <% end %>
              <% end %>
            <% elsif @current_category.nil? %>
              <% @categories.each do |cat| %>
                <%= link_to (@kind ? send("#{@kind}_channel_path", category_id: cat.id) : categories_path(category_id: cat.id)), class: "px-3 py-1.5 bg-slate-50 border border-slate-100 rounded-xl text-[11px] font-bold text-slate-600 hover:border-blue-400 hover:text-blue-600 hover:bg-white hover:shadow-sm transition-all" do %>
                  <%= cat.name %>
                <% end %>
              <% end %>
            <% else %>
              <span class="text-[10px] font-bold text-slate-300 uppercase tracking-widest italic">叶子分类 / End of Line</span>
            <% end %>
          </div>
        </div>
      </div>
    </nav>
  </div>

    <div class="max-w-2xl">
      <div class="inline-flex items-center px-3 py-1 bg-blue-50 rounded-full text-blue-600 text-[10px] font-black tracking-widest uppercase mb-3 border border-blue-100">
        <% case @kind
           when 'a' %> Professional Cooling
        <% when 'b' %> Smart Cooking
        <% when 'c' %> Industrial Stainless
        <% else %> Premium Equipment
        <% end %>
      </div>
      <h1 class="text-4xl font-black text-slate-900 tracking-tight leading-tight">
        <% if @current_category %>
          <%= @current_category.name %>
        <% elsif @kind %>
          <% case @kind
             when 'a' %> 制冷设备
          <% when 'b' %> 烹饪设备
          <% when 'c' %> 不锈钢餐饮用品
          <% end %>
        <% else %>
          探索 SINOWER 全系产品
        <% end %>
      </h1>
      <p class="text-slate-500 text-sm mt-2 font-medium max-w-lg">
        <% case @kind
           when 'a' %> 致力于为全球餐饮及零售行业提供最可靠的冷链技术支持，精准控温，极致节能。
        <% when 'b' %> 提供高效、智能的商用烹饪解决方案，让每一道佳肴都保持完美品质。
        <% when 'c' %> 高品质不锈钢餐饮设备，坚固耐用，易于清洁，符合最高卫生标准。
        <% else %> 领先的制冷及餐饮设备科技解决方案提供商。
        <% end %>
      </p>
    </div>

  <!-- SKU 列表 网格系统 -->
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-4 2xl:grid-cols-5 gap-6 mb-16">
    <% if @skus.any? %>
      <% @skus.each do |sku| %>
        <div class="group bg-white rounded-3xl border border-slate-100 overflow-hidden shadow-sm hover:shadow-2xl hover:shadow-blue-500/10 hover:border-blue-200 transition-all duration-500 flex flex-col h-full relative">
          <!-- 强制正方形图片容器 -->
          <div class="aspect-square bg-slate-50 relative overflow-hidden flex-shrink-0">
            <% if sku.image.attached? %>
              <% begin %>
                <%= image_tag sku.image, class: "w-full h-full object-contain p-2 group-hover:scale-105 transition-transform duration-700 ease-out", style: "background-color: transparent;" %>
              <% rescue ActiveStorage::FileNotFoundError %>
                <div class="w-full h-full flex flex-col items-center justify-center bg-gradient-to-br from-slate-50 to-slate-100">
                  <svg class="w-16 h-16 text-slate-200 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                  <span class="text-[9px] font-black text-slate-300 uppercase tracking-widest text-center px-2">File Lost (Re-upload)</span>
                </div>
              <% end %>
            <% else %>
              <div class="w-full h-full flex flex-col items-center justify-center bg-gradient-to-br from-slate-50 to-slate-100">
                <svg class="w-16 h-16 text-slate-200 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                <span class="text-[9px] font-black text-slate-300 uppercase tracking-widest">Image Coming Soon</span>
              </div>
            <% end %>
            
            <!-- 遮罩与操作 -->
            <div class="absolute inset-0 bg-slate-900/40 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col items-center justify-center backdrop-blur-[2px] p-6 text-center">
              <span class="text-[10px] text-white/80 font-bold tracking-widest uppercase mb-4 translate-y-4 group-hover:translate-y-0 transition-transform duration-500">SINOWER PREMIUM</span>
              <%= link_to sku_path(sku), class: "bg-white text-slate-900 px-6 py-2 rounded-full font-black text-[10px] tracking-widest uppercase shadow-xl hover:scale-105 transition-all transform translate-y-4 group-hover:translate-y-0 duration-500" do %>
                查看详情
              <% end %>
            </div>

            <!-- 右上角分类徽章 -->
            <div class="absolute top-3 right-3">
              <span class="bg-white/90 backdrop-blur-md px-2 py-1 rounded-lg text-[8px] font-black text-slate-900 shadow-sm border border-slate-100 tracking-tighter">
                <%= sku.category.name %>
              </span>
            </div>
          </div>

          <!-- 文本内容容器 -->
          <div class="p-5 flex flex-col flex-grow bg-white">
            <h3 class="text-sm font-black text-slate-900 mb-3 group-hover:text-blue-600 transition-colors duration-300 line-clamp-1">
              <%= sku.name %>
            </h3>
            
            <!-- 核心规格预览 -->
            <div class="grid grid-cols-2 gap-2 mb-4">
              <% if sku.category.category_kind == 'a' %>
                <div class="p-2 rounded-xl bg-slate-50 border border-slate-100 text-center">
                  <p class="text-[8px] font-black text-slate-400 uppercase mb-0.5">容积</p>
                  <p class="text-[10px] font-black text-slate-700 truncate"><%= sku.skuable.net_capacity %></p>
                </div>
                <div class="p-2 rounded-xl bg-blue-50/50 border border-blue-100/50 text-center">
                  <p class="text-[8px] font-black text-blue-400 uppercase mb-0.5">温度</p>
                  <p class="text-[10px] font-black text-blue-700 truncate"><%= sku.skuable.temp_range %></p>
                </div>
              <% elsif sku.category.category_kind == 'c' %>
                <div class="p-2 rounded-xl bg-slate-50 border border-slate-100 text-center">
                  <p class="text-[8px] font-black text-slate-400 uppercase mb-0.5">燃气类型</p>
                  <p class="text-[10px] font-black text-slate-700 truncate"><%= sku.skuable.gas_type %></p>
                </div>
                <div class="p-2 rounded-xl bg-blue-50/50 border border-blue-100/50 text-center">
                  <p class="text-[8px] font-black text-blue-400 uppercase mb-0.5">热负荷</p>
                  <p class="text-[10px] font-black text-blue-700 truncate"><%= sku.skuable.total_btu %></p>
                </div>
              <% else %>
                <div class="p-2 rounded-xl bg-slate-50 border border-slate-100 text-center col-span-2">
                  <p class="text-[8px] font-black text-slate-400 uppercase mb-0.5">尺寸</p>
                  <p class="text-[10px] font-black text-slate-700 truncate"><%= sku.skuable.unit_dimensions %></p>
                </div>
              <% end %>
            </div>

            <!-- 底部引导 -->
            <div class="mt-auto pt-4 border-t border-slate-50 flex items-center justify-between">
              <span class="flex items-center space-x-1">
                <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
                <span class="text-[8px] font-black text-slate-400 uppercase tracking-widest">In Production</span>
              </span>
              <%= link_to sku_path(sku), class: "text-blue-600" do %>
                <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
              <% end %>
            </div>
          </div>
          
          <%= link_to "", sku_path(sku), class: "absolute inset-0 z-0" %>
        </div>
      <% end %>
    <% else %>
      <div class="col-span-full py-24 text-center">
        <div class="bg-white rounded-[2rem] p-16 border border-slate-100 shadow-sm flex flex-col items-center">
          <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mb-6">
            <svg class="w-10 h-10 text-slate-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
          </div>
          <h2 class="text-xl font-black text-slate-900 mb-2">暂无可用型号</h2>
          <p class="text-slate-500 font-medium">该分类正在不断完善中，请稍后再来查看我们的最新发布。</p>
        </div>
      </div>
    <% end %>
  </div>

  <!-- 分页控件样式美化 -->
  <div class="flex justify-center mb-16">
    <%= paginate @skus %>
  </div>
</div>
