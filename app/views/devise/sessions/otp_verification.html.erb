<div class="min-h-screen flex flex-col items-center justify-center bg-slate-50 py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full space-y-8 bg-white p-8 rounded-xl shadow-lg">
    <div>
      <h2 class="mt-6 text-center text-3xl font-extrabold text-slate-900">
        Admin Verification
      </h2>
      <p class="mt-2 text-center text-sm text-slate-600">
        A verification code has been sent to your email.
      </p>
    </div>

    <%= form_with url: verify_otp_path, method: :post, class: "mt-8 space-y-6" do |f| %>
      <div class="rounded-md shadow-sm">
        <div>
          <%= f.label :otp, "Verification Code", class: "sr-only" %>
          <%= f.text_field :otp, required: true, autofocus: true, 
              class: "appearance-none relative block w-full px-3 py-4 border border-slate-300 placeholder-slate-500 text-slate-900 rounded-md focus:outline-none focus:ring-blue-500 focus:border-blue-500 focus:z-10 text-center text-2xl tracking-[1em] font-mono", 
              placeholder: "000000", maxlength: 6 %>
        </div>
      </div>

      <div>
        <%= f.submit "Verify and Login", class: "group relative w-full flex justify-center py-2 px-4 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
      </div>
    <% end %>

    <div class="flex items-center justify-between mt-4">
      <div class="text-sm">
        <%= button_to "Resend Code", resend_otp_path, method: :post, class: "font-medium text-blue-600 hover:text-blue-500 bg-transparent border-0 cursor-pointer" %>
      </div>
      <div class="text-sm">
        <%= link_to "Back to Login", new_user_session_path, class: "font-medium text-slate-600 hover:text-slate-500" %>
      </div>
    </div>
    
    <hr class="my-6 border-slate-200">

    <div>
      <h2 class="text-center text-2xl font-extrabold text-slate-900">
        后台安全验证
      </h2>
      <p class="mt-2 text-center text-sm text-slate-600">
        验证码已发送至您的邮箱，请输入 6 位验证码完成登录。
      </p>
    </div>
  </div>
</div>