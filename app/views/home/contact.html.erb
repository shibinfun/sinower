<div class="relative bg-slate-900 py-24 overflow-hidden">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-[10%] -left-[10%] w-[40%] h-[40%] bg-blue-600/20 rounded-full blur-[120px]"></div>
    <div class="absolute top-[20%] -right-[10%] w-[30%] h-[50%] bg-purple-600/10 rounded-full blur-[100px]"></div>
  </div>

    <div class="relative max-w-screen-xl mx-auto px-6 text-center">
    <div class="inline-flex items-center px-4 py-2 bg-blue-500/10 border border-blue-500/20 rounded-full text-blue-400 text-xs font-bold tracking-widest uppercase mb-8 backdrop-blur-sm">
      <span class="w-2 h-2 bg-blue-400 rounded-full mr-3"></span>
      <%= t('home.contact.subtitle') %>
    </div>
    <h1 class="text-5xl md:text-6xl font-black text-white tracking-tight mb-8">
      <%= t('home.contact.hero_title').html_safe %>
    </h1>
    <p class="max-w-2xl mx-auto text-slate-400 text-lg font-medium">
      <%= t('home.contact.hero_desc') %>
    </p>
  </div>
</div>

<div class="bg-white py-24">
  <div class="max-w-screen-xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16">
    <!-- Contact Form -->
    <div class="bg-slate-50 p-8 md:p-12 rounded-[2.5rem] border border-slate-100 shadow-2xl shadow-blue-500/5">
      <h2 class="text-2xl font-black text-slate-900 mb-8"><%= t('home.contact.send_message') %></h2>
      
      <%= form_with(model: @contact_message, url: contact_path, local: true, class: "space-y-6", x_data: "{ agreed: false }", "@submit.prevent": "if(agreed) $el.submit(); else alert('#{t('home.contact.form.privacy_error')}')") do |f| %>
        <% if @contact_message.errors.any? %>
          <div class="p-4 bg-red-50 border border-red-100 rounded-xl text-red-800 text-sm">
            <ul class="list-disc pl-5">
              <% @contact_message.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <%= f.label :name, t('home.contact.form.name'), class: "block text-xs font-black text-slate-500 uppercase tracking-widest mb-2" %>
            <%= f.text_field :name, required: true, class: "w-full px-5 py-4 bg-white border border-slate-200 rounded-2xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all font-medium text-slate-900 placeholder-slate-300", placeholder: t('home.contact.form.name_placeholder') %>
          </div>
          <div>
            <%= f.label :email, t('home.contact.form.email'), class: "block text-xs font-black text-slate-500 uppercase tracking-widest mb-2" %>
            <%= f.email_field :email, required: true, class: "w-full px-5 py-4 bg-white border border-slate-200 rounded-2xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all font-medium text-slate-900 placeholder-slate-300", placeholder: t('home.contact.form.email_placeholder') %>
          </div>
        </div>

        <div>
          <%= f.label :subject, t('home.contact.form.subject'), class: "block text-xs font-black text-slate-500 uppercase tracking-widest mb-2" %>
          <%= f.text_field :subject, required: true, class: "w-full px-5 py-4 bg-white border border-slate-200 rounded-2xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all font-medium text-slate-900 placeholder-slate-300", placeholder: t('home.contact.form.subject_placeholder') %>
        </div>

        <div>
          <%= f.label :message, t('home.contact.form.message'), class: "block text-xs font-black text-slate-500 uppercase tracking-widest mb-2" %>
          <%= f.text_area :message, required: true, rows: 6, class: "w-full px-5 py-4 bg-white border border-slate-200 rounded-2xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all font-medium text-slate-900 placeholder-slate-300", placeholder: t('home.contact.form.message_placeholder') %>
        </div>

        <div class="flex items-start space-x-3 pt-2">
          <div class="flex items-center h-5">
            <%= check_box_tag :privacy_agreement, "1", false, x_model: "agreed", class: "w-5 h-5 text-blue-600 border-slate-300 rounded focus:ring-blue-500 cursor-pointer" %>
          </div>
          <div class="text-sm">
            <label for="privacy_agreement" class="font-medium text-slate-600">
              <%= t('home.contact.form.privacy_policy_agree') %>
              <button type="button" @click="$dispatch('open-privacy')" class="text-blue-600 hover:text-blue-700 font-bold underline underline-offset-4">
                <%= t('home.contact.form.privacy_policy_link') %>
              </button>
            </label>
          </div>
        </div>

        <%= f.submit t('home.contact.form.submit'), class: "w-full py-5 bg-blue-600 hover:bg-blue-700 text-white rounded-[1.5rem] font-black text-sm tracking-widest uppercase transition-all shadow-xl shadow-blue-500/30 cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed", ":disabled": "!agreed" %>
      <% end %>
    </div>

    <div class="flex flex-col justify-center">
      <div class="space-y-12">
        <div>
          <h2 class="text-3xl font-black text-slate-900 mb-6 tracking-tight"><%= t('home.contact.address_title') %></h2>
          <p class="text-slate-500 font-medium text-lg leading-relaxed">
            <%= t('contact_info.address').gsub(', ', '<br/>').html_safe %>
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="p-8 bg-slate-50 rounded-[2rem] border border-slate-100">
            <div class="w-12 h-12 bg-blue-600 rounded-xl flex items-center justify-center mb-6 shadow-lg shadow-blue-600/20">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            </div>
            <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest mb-2"><%= t('home.contact.phone_title') %></h3>
            <p class="text-xl font-black text-slate-900 tracking-tight"><%= t('contact_info.phone') %></p>
          </div>

          <div class="p-8 bg-slate-50 rounded-[2rem] border border-slate-100">
            <div class="w-12 h-12 bg-blue-600 rounded-xl flex items-center justify-center mb-6 shadow-lg shadow-blue-600/20">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </div>
            <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest mb-2"><%= t('home.contact.email_title') %></h3>
            <p class="text-base font-black text-slate-900 tracking-tight mb-1"><%= t('contact_info.email') %></p>
            <p class="text-sm font-bold text-blue-600"><%= t('contact_info.support_email') %></p>
          </div>
        </div>

        <div class="p-8 bg-slate-900 rounded-[2.5rem] text-white relative overflow-hidden">
          <div class="absolute -bottom-10 -right-10 w-32 h-32 bg-blue-600 rounded-full blur-3xl opacity-20"></div>
          <h3 class="text-xl font-black mb-4 relative z-10"><%= t('home.contact.support_card_title') %></h3>
          <p class="text-slate-400 text-sm mb-6 relative z-10 leading-relaxed">
            <%= t('home.contact.support_card_desc') %>
          </p>
          <%= link_to warranty_path, class: "inline-flex items-center text-blue-400 font-black text-xs tracking-widest uppercase hover:text-blue-300 transition-colors relative z-10" do %>
            <%= t('home.contact.view_warranty') %>
            <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
