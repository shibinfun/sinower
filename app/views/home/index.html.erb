<!-- Hero Section with Tech Dark Theme -->
<div class="relative bg-slate-900 overflow-hidden">
  <!-- Decorative background elements -->
  <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none">
    <div class="absolute -top-[10%] -left-[10%] w-[40%] h-[40%] bg-blue-600/20 rounded-full blur-[120px]"></div>
    <div class="absolute top-[20%] -right-[10%] w-[30%] h-[50%] bg-purple-600/10 rounded-full blur-[100px]"></div>
  </div>

    <div class="relative max-w-screen-xl mx-auto px-6 py-24 lg:py-32 flex flex-col items-center text-center">
    <div class="inline-flex items-center px-4 py-2 bg-blue-500/10 border border-blue-500/20 rounded-full text-blue-400 text-xs font-bold tracking-widest uppercase mb-8 backdrop-blur-sm animate-pulse">
      <span class="w-2 h-2 bg-blue-400 rounded-full mr-3"></span>
      GLOBAL MANUFACTURING EXPERTISE SINCE 2005
    </div>
    
    <h1 class="text-5xl md:text-7xl font-black text-white tracking-tight mb-8 leading-[1.1]">
      20年行业积淀<br/>
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-cyan-300">助力美国冷链未来</span>
    </h1>
    
    <p class="max-w-2xl text-slate-400 text-lg md:text-xl font-medium mb-12 leading-relaxed">
      SINOWER USA 依托二十余年全球制造经验，深耕欧洲与中东市场。如今，我们落户佐治亚州，为全美餐饮行业提供工厂直供的高端商用设备与本土技术支持。
    </p>
    
    <div class="flex flex-col sm:flex-row gap-4">
      <%= link_to all_products_path, class: "px-10 py-4 bg-blue-600 hover:bg-blue-700 text-white rounded-2xl font-black text-sm tracking-widest uppercase transition-all shadow-2xl shadow-blue-600/20 group flex items-center" do %>
        探索全线产品
        <svg class="w-5 h-5 ml-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
      <% end %>
      <%= link_to contact_path, class: "px-10 py-4 bg-slate-800 hover:bg-slate-700 text-white border border-slate-700 rounded-2xl font-black text-sm tracking-widest uppercase transition-all" do %>
        联系我们
      <% end %>
    </div>

    <!-- Stats Preview -->
    <div class="mt-20 grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-16">
      <div>
        <div class="text-3xl font-black text-white mb-1">500+</div>
        <div class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">服务客户</div>
      </div>
      <div>
        <div class="text-3xl font-black text-white mb-1">120+</div>
        <div class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">专利技术</div>
      </div>
      <div>
        <div class="text-3xl font-black text-white mb-1">24/7</div>
        <div class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">技术支持</div>
      </div>
      <div>
        <div class="text-3xl font-black text-white mb-1">A++</div>
        <div class="text-[10px] font-bold text-slate-500 uppercase tracking-widest">能效等级</div>
      </div>
    </div>
  </div>
</div>

<!-- Features Section -->
<div class="bg-white py-24">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-black text-slate-900 tracking-tight mb-4">核心科技优势</h2>
      <div class="h-1.5 w-20 bg-blue-600 mx-auto rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Feature 1 -->
      <div class="group p-8 bg-slate-50 rounded-[2.5rem] border border-slate-100 hover:bg-white hover:shadow-2xl hover:shadow-blue-500/10 transition-all duration-500">
        <div class="w-16 h-16 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-xl shadow-blue-600/20 group-hover:-translate-y-2 transition-transform duration-500">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H5a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
        </div>
        <h3 class="text-xl font-black text-slate-900 mb-4 tracking-tight">工厂直供价值</h3>
        <p class="text-slate-500 font-medium leading-relaxed">
          纵向一体化的制造体系，消减中间环节。我们从工厂直接发货至佐治亚仓库，为您提供极具竞争力的价格优势与卓越品质。
        </p>
      </div>

      <!-- Feature 2 -->
      <div class="group p-8 bg-slate-50 rounded-[2.5rem] border border-slate-100 hover:bg-white hover:shadow-2xl hover:shadow-blue-500/10 transition-all duration-500">
        <div class="w-16 h-16 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-xl shadow-blue-600/20 group-hover:-translate-y-2 transition-transform duration-500">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01m-.01 4h.01"></path></svg>
        </div>
        <h3 class="text-xl font-black text-slate-900 mb-4 tracking-tight">全美库存保障</h3>
        <p class="text-slate-500 font-medium leading-relaxed">
          在全美建立分分销网络，佐治亚中心常备现货。配合未来三年的九大分支机构计划，确保快速履行与稳定的设备供应。
        </p>
      </div>

      <!-- Feature 3 -->
      <div class="group p-8 bg-slate-50 rounded-[2.5rem] border border-slate-100 hover:bg-white hover:shadow-2xl hover:shadow-blue-500/10 transition-all duration-500">
        <div class="w-16 h-16 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-xl shadow-blue-600/20 group-hover:-translate-y-2 transition-transform duration-500">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
        </div>
        <h3 class="text-xl font-black text-slate-900 mb-4 tracking-tight">本土专业支持</h3>
        <p class="text-slate-500 font-medium leading-relaxed">
          由工厂直接派驻的技术团队常驻美国，提供深度保修服务与技术培训，让每一位经销商和用户都能获得 24/7 的安心保障。
        </p>
      </div>
    </div>
  </div>
</div>
