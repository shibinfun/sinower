<% content_for :title, "#{t('home.about.title')} - SINOWER USA" %>

<!-- Hero Section: 关于我们 -->
<div class="relative bg-slate-900 py-24 overflow-hidden">
  <div class="absolute inset-0 z-0 opacity-20">
    <!-- 这里可以放背景图 -->
    <div class="absolute inset-0 bg-gradient-to-r from-blue-900/50 to-transparent"></div>
  </div>
  
  <div class="relative z-10 max-w-screen-xl mx-auto px-6 text-center lg:text-left">
    <div class="inline-flex items-center px-4 py-2 bg-blue-500/10 border border-blue-500/20 rounded-full text-blue-400 text-xs font-bold tracking-widest uppercase mb-6 backdrop-blur-sm">
      <span class="w-2 h-2 bg-blue-400 rounded-full mr-3 animate-pulse"></span>
      <%= t('home.about.subtitle') %>
    </div>
    <h1 class="text-5xl md:text-6xl font-black text-white tracking-tight mb-6">
      <%= t('home.about.hero_title') %> <span class="text-blue-500">USA</span>
    </h1>
    <p class="max-w-2xl text-slate-400 text-lg font-medium leading-relaxed">
      <%= t('home.about.hero_desc') %>
    </p>
  </div>
</div>

<!-- 核心板块：历史与实力 -->
<div class="py-24 bg-white">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div class="space-y-8">
        <div>
          <h2 class="text-3xl font-black text-slate-900 mb-6 tracking-tight"><%= t('home.about.heritage_title') %></h2>
          <p class="text-slate-600 leading-relaxed font-medium">
            <%= t('home.about.heritage_desc_1') %>
          </p>
          <p class="text-slate-600 mt-4 leading-relaxed font-medium">
            <%= t('home.about.heritage_desc_2') %>
          </p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="p-6 bg-slate-50 rounded-3xl border border-slate-100 group hover:bg-white hover:shadow-xl transition-all">
            <div class="text-blue-600 font-black text-2xl mb-2">20+</div>
            <p class="text-xs font-bold text-slate-400 uppercase tracking-widest"><%= t('home.about.stats.years') %></p>
          </div>
          <div class="p-6 bg-slate-50 rounded-3xl border border-slate-100 group hover:bg-white hover:shadow-xl transition-all">
            <div class="text-blue-600 font-black text-2xl mb-2">7+</div>
            <p class="text-xs font-bold text-slate-400 uppercase tracking-widest"><%= t('home.about.stats.subsidiaries') %></p>
          </div>
        </div>
      </div>
      
      <div class="relative">
        <div class="aspect-[4/3] rounded-[3rem] overflow-hidden shadow-2xl">
          <%= image_tag "factory.avif", class: "w-full h-full object-contain p-2", alt: "Sinower Factory" %>
          <div class="absolute inset-0 bg-blue-600/10 mix-blend-overlay"></div>
        </div>
        <div class="absolute -bottom-8 -left-8 w-48 h-48 bg-blue-600 rounded-[2rem] -z-10 animate-blob"></div>
      </div>
    </div>
  </div>
</div>

<!-- 核心产品线 -->
<div class="py-24 bg-slate-50">
  <div class="max-w-screen-xl mx-auto px-6 text-center">
    <h2 class="text-3xl font-black text-slate-900 mb-16 tracking-tight"><%= t('home.about.product_lines_title') %></h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <% [
        { name: t('home.about.product_lines.refrigeration'), sub: "Commercial Refrigeration", icon: "M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" },
        { name: t('home.about.product_lines.cooking'), sub: "Commercial Cooking", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
        { name: t('home.about.product_lines.stainless'), sub: "Stainless Foodservice", icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" }
      ].each do |line| %>
        <div class="p-10 bg-white rounded-[2.5rem] border border-slate-100 shadow-sm hover:shadow-2xl hover:shadow-blue-500/10 transition-all group">
          <div class="w-16 h-16 bg-blue-100 rounded-2xl flex items-center justify-center mb-8 mx-auto text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-colors">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="<%= line[:icon] %>"></path></svg>
          </div>
          <h3 class="text-xl font-black text-slate-900 mb-2"><%= line[:name] %></h3>
          <p class="text-xs font-bold text-slate-400 uppercase tracking-widest"><%= line[:sub] %></p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- 制造实力与竞争价值 -->
<div class="py-24 bg-white">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div class="order-2 lg:order-1 relative">
        <div class="aspect-[4/3] rounded-[3rem] overflow-hidden shadow-2xl">
          <%= image_tag "office.avif", class: "w-full h-full object-contain p-2", alt: "Sinower USA Office" %>
        </div>
        <div class="absolute -top-8 -right-8 w-48 h-48 bg-slate-900 rounded-[2rem] -z-10"></div>
      </div>
      
      <div class="order-1 lg:order-2 space-y-8">
        <div>
          <h2 class="text-3xl font-black text-slate-900 mb-6 tracking-tight"><%= t('home.about.value_title') %></h2>
          <p class="text-slate-600 leading-relaxed font-medium">
            <%= t('home.about.value_desc_1') %>
          </p>
          <p class="text-slate-600 mt-4 leading-relaxed font-medium">
            <%= t('home.about.value_desc_2') %>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- 美国扩张计划 -->
<div class="py-24 bg-slate-900 text-white overflow-hidden relative">
  <div class="absolute top-0 right-0 w-1/2 h-full bg-blue-600/10 skew-x-12 translate-x-1/4"></div>
  
  <div class="relative z-10 max-w-screen-xl mx-auto px-6">
    <div class="max-w-3xl">
      <h2 class="text-4xl font-black mb-8 tracking-tight"><%= t('home.about.expansion_title') %></h2>
      <p class="text-slate-400 text-lg leading-relaxed mb-12">
        <%= t('home.about.expansion_desc') %>
      </p>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="p-8 bg-white/5 rounded-3xl border border-white/10 backdrop-blur-sm">
          <div class="text-3xl font-black text-blue-400 mb-2">9</div>
          <p class="text-sm font-bold text-slate-500 uppercase tracking-widest leading-tight"><%= t('home.about.expansion_stats.offices') %></p>
        </div>
        <div class="p-8 bg-white/5 rounded-3xl border border-white/10 backdrop-blur-sm">
          <div class="text-3xl font-black text-blue-400 mb-2">3</div>
          <p class="text-sm font-bold text-slate-500 uppercase tracking-widest leading-tight"><%= t('home.about.expansion_stats.plan') %></p>
        </div>
        <div class="p-8 bg-white/5 rounded-3xl border border-white/10 backdrop-blur-sm">
          <div class="text-3xl font-black text-blue-400 mb-2">Coast</div>
          <p class="text-sm font-bold text-slate-500 uppercase tracking-widest leading-tight"><%= t('home.about.expansion_stats.efficiency') %></p>
        </div>
      </div>
      
      <p class="mt-12 text-slate-400 font-medium leading-relaxed">
        <%= t('home.about.expansion_footer') %>
      </p>
    </div>
  </div>
</div>

<!-- 合作伙伴与承诺 -->
<div class="py-24 bg-white">
  <div class="max-w-screen-xl mx-auto px-6 text-center">
    <h2 class="text-3xl font-black text-slate-900 mb-8 tracking-tight"><%= t('home.about.commitment_title') %></h2>
    <p class="max-w-3xl mx-auto text-slate-500 text-lg font-medium leading-relaxed mb-16">
      <%= t('home.about.commitment_desc') %>
    </p>
    
    <div class="bg-blue-600 rounded-[3rem] p-12 lg:p-20 text-white relative overflow-hidden">
      <div class="absolute top-0 left-0 w-full h-full bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] opacity-10"></div>
      <div class="relative z-10">
        <h3 class="text-4xl font-black mb-8 tracking-tight"><%= t('home.about.become_dealer_title') %></h3>
        <p class="text-blue-100 text-xl font-medium mb-12 max-w-2xl mx-auto">
          <%= t('home.about.become_dealer_desc') %>
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-6">
          <%= link_to contact_path, class: "px-10 py-5 bg-white text-blue-600 rounded-2xl font-black text-sm tracking-widest uppercase hover:bg-slate-50 transition-all shadow-xl" do %>
            <%= t('home.about.apply_now') %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- 为什么选择 SINOWER? -->
<div class="py-24 bg-slate-50">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-black text-slate-900 tracking-tight"><%= t('home.about.why_title') %></h2>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% [
        { title: t('home.about.reasons.pricing.title'), desc: t('home.about.reasons.pricing.desc') },
        { title: t('home.about.reasons.support.title'), desc: t('home.about.reasons.support.desc') },
        { title: t('home.about.reasons.standards.title'), desc: t('home.about.reasons.standards.desc') },
        { title: t('home.about.reasons.opportunity.title'), desc: t('home.about.reasons.opportunity.desc') },
        { title: t('home.about.reasons.inventory.title'), desc: t('home.about.reasons.inventory.desc') }
      ].each do |item| %>
        <div class="p-8 bg-white rounded-3xl border border-slate-100 hover:shadow-xl transition-all">
          <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          </div>
          <h4 class="text-lg font-black text-slate-900 mb-4"><%= item[:title] %></h4>
          <p class="text-slate-500 text-sm font-medium leading-relaxed"><%= item[:desc] %></p>
        </div>
      <% end %>
    </div>
  </div>
</div>
