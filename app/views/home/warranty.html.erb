<div class="relative bg-slate-900 pt-32 pb-24 overflow-hidden">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-[10%] -right-[10%] w-[40%] h-[40%] bg-blue-600/10 rounded-full blur-[120px]"></div>
    <div class="absolute top-[20%] -left-[10%] w-[30%] h-[30%] bg-cyan-600/5 rounded-full blur-[100px]"></div>
  </div>

  <div class="relative max-w-screen-xl mx-auto px-6">
    <div class="max-w-5xl mx-auto text-center">
      <div class="inline-flex items-center px-4 py-2 bg-blue-500/10 border border-blue-500/20 rounded-full text-blue-400 text-xs font-bold tracking-widest uppercase mb-8 backdrop-blur-sm">
        <%= t('home.warranty.subtitle') %>
      </div>
      <h1 class="text-3xl md:text-5xl font-black text-white tracking-wider mb-8 leading-[1.2]">
        <%= t('home.warranty.hero_title_1') %><br/>
        <%= t('home.warranty.hero_title_2') %><br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-cyan-300">
          <%= t('home.warranty.hero_title_3') %>
        </span>
      </h1>
      <p class="text-slate-400 text-xl font-medium mb-12 leading-relaxed max-w-2xl mx-auto">
        <%= t('home.warranty.hero_desc') %>
      </p>
    </div>

    <!-- 核心保修政策卡片 -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-16">
      <% [
        { key: 'parts_labor', icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z' },
        { key: 'compressor', icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
        { key: 'service', icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z' }
      ].each do |item| %>
        <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-[2.5rem] p-10 group hover:bg-white/10 transition-all duration-500">
          <div class="w-16 h-16 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-2xl shadow-blue-600/30 group-hover:scale-110 transition-transform duration-500">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="<%= item[:icon] %>"></path></svg>
          </div>
          <h3 class="text-3xl font-black text-white mb-2 tracking-tight">
            <%= t("home.warranty.core_cards.#{item[:key]}.title") %>
          </h3>
          <p class="text-blue-400 font-bold uppercase tracking-widest text-sm mb-4">
            <%= t("home.warranty.core_cards.#{item[:key]}.subtitle") %>
          </p>
          <p class="text-slate-400 font-medium">
            <%= t("home.warranty.core_cards.#{item[:key]}.desc") %>
          </p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<div class="bg-white py-24" x-data="{ openModal: false, productType: '' }">
  <div class="max-w-screen-xl mx-auto px-6">
    <!-- 保修覆盖范围表格 -->
    <div class="mb-32">
      <h2 class="text-4xl font-black text-slate-900 mb-12 tracking-tight">
        <%= t('home.warranty.coverage.title') %>
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <% [
          { key: 'refrigeration', color: 'blue' },
          { key: 'cooking', color: 'orange' },
          { key: 'stainless', color: 'slate' }
        ].each do |item| %>
          <div class="flex flex-col bg-slate-50 rounded-[3rem] p-10 border border-slate-100 hover:shadow-2xl transition-all duration-500">
            <h3 class="text-2xl font-black text-slate-900 mb-6"><%= t("home.warranty.coverage.#{item[:key]}.title") %></h3>
            <div class="inline-block px-4 py-2 bg-slate-900 text-white rounded-xl text-sm font-black mb-6 self-start uppercase tracking-tight">
              <%= t("home.warranty.coverage.#{item[:key]}.period") %>
            </div>
            <p class="text-slate-500 font-medium leading-relaxed mb-8 flex-grow">
              <%= t("home.warranty.coverage.#{item[:key]}.desc") %>
              <% if t("home.warranty.coverage.#{item[:key]}.extra", default: "").present? %>
                <br/><br/>
                <span class="text-slate-900 font-bold"><%= t("home.warranty.coverage.#{item[:key]}.extra") %></span>
              <% end %>
            </p>
            <div class="space-y-3">
              <% pdf = case item[:key]
                  when 'refrigeration' then @refrigeration_pdf
                  when 'cooking' then @cooking_pdf
                  when 'stainless' then @stainless_pdf
                  end %>
              
              <% if pdf&.file&.attached? %>
                <%= link_to rails_blob_path(pdf.file, disposition: "attachment"), 
                    class: "w-full py-4 bg-blue-900 hover:bg-slate-900 text-white rounded-2xl font-black text-sm transition-all flex items-center justify-center space-x-2 shadow-lg shadow-blue-900/20", 
                    download: "SINOWER_Warranty_#{item[:key]}.pdf" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
                  <span><%= t('home.warranty.view_details') %></span>
                <% end %>
              <% else %>
                <div class="w-full py-4 bg-gray-300 text-gray-500 rounded-2xl font-black text-sm flex items-center justify-center space-x-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                  <span>PDF 暂未上传</span>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- 服务流程 -->
    <div class="mb-32">
      <h2 class="text-4xl font-black text-slate-900 mb-16 tracking-tight text-center">
        <%= t('home.warranty.process.title') %>
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 relative">
        <!-- 装饰连线 -->
        <div class="hidden md:block absolute top-12 left-[10%] right-[10%] h-0.5 bg-slate-100 -z-0"></div>
        
        <% [1, 2, 3].each do |i| %>
          <div class="relative z-10 text-center flex flex-col items-center">
            <div class="w-24 h-24 bg-white border-8 border-slate-50 rounded-full flex items-center justify-center mb-8 shadow-xl text-3xl font-black text-blue-600">
              0<%= i %>
            </div>
            <h4 class="text-2xl font-black text-slate-900 mb-4 tracking-tight"><%= t("home.warranty.process.step#{i}.title") %></h4>
            <p class="text-slate-500 font-medium leading-relaxed px-4"><%= t("home.warranty.process.step#{i}.desc") %></p>
          </div>
        <% end %>
      </div>

      <div class="mt-16 text-center">
        <% if @claim_form_pdf&.file&.attached? %>
          <%= link_to rails_blob_path(@claim_form_pdf.file, disposition: "attachment"), 
              class: "inline-flex items-center px-10 py-5 bg-blue-900 hover:bg-slate-900 text-white rounded-2xl font-black text-lg transition-all shadow-xl shadow-blue-900/20 active:scale-95", 
              download: "Submit_Warranty_Claim.pdf" do %>
            <span><%= t('home.warranty.submit_claim_download') %></span>
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
          <% end %>
        <% else %>
          <div class="inline-flex items-center px-10 py-5 bg-gray-300 text-gray-500 rounded-2xl font-black text-lg shadow-xl shadow-gray-300/20">
            <svg class="w-5 h-5 ml-2 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <span>索赔表单 PDF 暂未上传</span>
          </div>
        <% end %>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-32">
      <!-- 保修排除条款 -->
      <section class="bg-slate-900 rounded-[3rem] p-12 text-white relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-blue-600 rounded-full blur-[100px] opacity-20"></div>
        <div class="relative z-10">
          <h2 class="text-3xl font-black mb-4 tracking-tight"><%= t('home.warranty.exclusions_section.title') %></h2>
          <p class="text-slate-400 font-medium mb-8"><%= t('home.warranty.exclusions_section.desc') %></p>
          <ul class="space-y-5">
            <% %w[improper_install unauthorized misuse transport natural_disaster].each do |key| %>
              <li class="flex items-start group">
                <div class="w-6 h-6 rounded-full bg-red-500/10 border border-red-500/20 flex items-center justify-center mr-4 mt-0.5 shrink-0 transition-colors group-hover:bg-red-500 group-hover:border-red-500">
                  <svg class="w-3.5 h-3.5 text-red-500 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>
                </div>
                <span class="text-slate-300 font-medium group-hover:text-white transition-colors">
                  <%= t("home.warranty.exclusions_section.items.#{key}") %>
                </span>
              </li>
            <% end %>
          </ul>
        </div>
      </section>

      <!-- 责任限制 -->
      <section class="bg-slate-50 rounded-[3rem] p-12 border border-slate-100">
        <h2 class="text-3xl font-black text-slate-900 mb-4 tracking-tight"><%= t('home.warranty.liability.title') %></h2>
        <p class="text-slate-500 font-medium mb-8 leading-relaxed"><%= t('home.warranty.liability.desc') %></p>
        <ul class="space-y-5">
          <% %w[food_loss profit_loss economic_loss].each do |key| %>
            <li class="flex items-start group">
              <div class="w-6 h-6 rounded-full bg-slate-200 flex items-center justify-center mr-4 mt-0.5 shrink-0 group-hover:bg-slate-900 transition-colors">
                <div class="w-1.5 h-1.5 rounded-full bg-slate-500 group-hover:bg-white"></div>
              </div>
              <span class="text-slate-600 font-bold group-hover:text-slate-900 transition-colors">
                <%= t("home.warranty.liability.items.#{key}") %>
              </span>
            </li>
          <% end %>
        </ul>
        <div class="mt-12">
          <button @click="openModal = true; productType = 'General Warranty'" class="px-8 py-4 bg-slate-900 hover:bg-slate-800 text-white rounded-2xl font-black transition-all">
            <%= t('home.warranty.submit_claim_btn') %>
          </button>
        </div>
      </section>
    </div>

    <!-- 服务部门与备件支持 -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-32">
      <div class="bg-blue-600 rounded-[3rem] p-10 text-white flex flex-col justify-between h-full relative overflow-hidden group">
        <div class="absolute top-0 right-0 w-48 h-48 bg-white/10 rounded-full -mr-24 -mt-24 blur-3xl transition-all group-hover:bg-white/20"></div>
        <div class="relative z-10">
          <h2 class="text-3xl font-black mb-6 tracking-tight"><%= t('home.warranty.service_dept.title') %></h2>
          <div class="space-y-6 mb-8">
            <div class="flex flex-col">
              <span class="text-blue-100 font-bold uppercase tracking-widest text-[10px] mb-1"><%= t('home.warranty.service_dept.email_label') %></span>
              <a href="mailto:support@sinowerus.com" class="text-2xl font-black hover:underline decoration-2 underline-offset-4">support@sinowerus.com</a>
            </div>
            <div class="flex flex-col">
              <span class="text-blue-100 font-bold uppercase tracking-widest text-[10px] mb-1"><%= t('home.warranty.service_dept.service_hours') %></span>
              <span class="text-xl font-bold"><%= t('home.warranty.service_dept.hours_value') %></span>
            </div>
          </div>
          <div class="p-5 bg-white/10 backdrop-blur-md rounded-2xl border border-white/10">
            <p class="text-blue-50 text-sm font-medium">
              <%= t('home.warranty.service_dept.response_time') %>
            </p>
          </div>
        </div>
      </div>

      <div class="bg-slate-900 rounded-[3rem] p-10 text-white flex flex-col justify-between h-full relative overflow-hidden group border border-white/5 shadow-2xl">
        <div class="absolute bottom-0 right-0 w-64 h-64 bg-blue-600/10 rounded-full blur-[80px]"></div>
        <div class="relative z-10">
          <div class="flex items-center space-x-4 mb-6">
            <div class="w-12 h-12 bg-blue-600 rounded-xl flex items-center justify-center shadow-lg shadow-blue-600/20">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"></path></svg>
            </div>
            <h2 class="text-3xl font-black tracking-tight"><%= t('home.warranty.service_dept.parts_support') %></h2>
          </div>
          <p class="text-slate-400 font-medium leading-relaxed mb-10 max-w-md">
            <%= t('home.warranty.service_dept.parts_desc') %>
          </p>
          <div class="mt-auto">
            <% if @spare_parts_pdf&.file&.attached? %>
              <%= link_to rails_blob_path(@spare_parts_pdf.file, disposition: "attachment"), 
                  class: "inline-flex items-center px-8 py-4 bg-blue-600 hover:bg-blue-500 text-white rounded-2xl font-black transition-all shadow-lg shadow-blue-600/20 group active:scale-95", 
                  download: "Request_Spare_Parts.pdf" do %>
                <span><%= t('home.warranty.service_dept.request_parts_btn') %></span>
                <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
              <% end %>
            <% else %>
              <div class="inline-flex items-center px-8 py-4 bg-gray-300 text-gray-500 rounded-2xl font-black transition-all shadow-lg shadow-gray-300/20">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                <span>备件申请表 PDF 暂未上传</span>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 反馈表单弹窗 -->
  <div x-show="openModal" 
       x-transition:enter="transition ease-out duration-300"
       x-transition:enter-start="opacity-0 scale-95"
       x-transition:enter-end="opacity-100 scale-100"
       x-transition:leave="transition ease-in duration-200"
       x-transition:leave-start="opacity-100 scale-100"
       x-transition:leave-end="opacity-0 scale-95"
       class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/80 backdrop-blur-sm"
       x-cloak>
    <div class="bg-white rounded-[2rem] w-full max-w-2xl overflow-hidden shadow-2xl relative" @click.away="openModal = false">
      <div class="p-8 border-b border-slate-100 flex items-center justify-between bg-slate-50">
        <h3 class="text-2xl font-black text-slate-900 tracking-tight">
          <%= t('home.warranty.feedback_btn') %>: 
          <span x-text="productType === 'General Warranty' ? '<%= t('home.warranty.form.product_type') %>' : 
                        (productType === 'Commercial Refrigeration' ? '<%= t('home.warranty.product_lines.refrigeration') %>' : 
                        (productType === 'Cooking Equipment' ? '<%= t('home.warranty.product_lines.cooking') %>' : '<%= t('home.warranty.product_lines.stainless') %>'))"></span>
        </h3>
        <button @click="openModal = false" class="text-slate-400 hover:text-slate-600">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      
      <%= form_with model: @warranty_inquiry, url: warranty_inquiry_path, class: "p-8 space-y-6 max-h-[70vh] overflow-y-auto" do |f| %>
        <%= f.hidden_field :product_type, ":value": "productType" %>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <%= f.label :subject, t('home.warranty.form.subject'), class: "text-xs font-bold text-slate-500 uppercase tracking-widest" %>
            <%= f.text_field :subject, required: true, placeholder: t('home.warranty.form.placeholder.subject'), class: "w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all" %>
          </div>
          <div class="space-y-2">
            <%= f.label :model_number, t('home.warranty.form.model_number'), class: "text-xs font-bold text-slate-500 uppercase tracking-widest" %>
            <%= f.text_field :model_number, required: true, placeholder: t('home.warranty.form.placeholder.model_number'), class: "w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all" %>
          </div>
        </div>

        <div class="space-y-2">
          <%= f.label :description, t('home.warranty.form.description'), class: "text-xs font-bold text-slate-500 uppercase tracking-widest" %>
          <%= f.text_area :description, rows: 4, required: true, placeholder: t('home.warranty.form.placeholder.description'), class: "w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all resize-none" %>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="space-y-2">
            <%= f.label :name, t('home.warranty.form.name'), class: "text-xs font-bold text-slate-500 uppercase tracking-widest" %>
            <%= f.text_field :name, required: true, placeholder: t('home.warranty.form.placeholder.name'), class: "w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all" %>
          </div>
          <div class="space-y-2">
            <%= f.label :phone, t('home.warranty.form.phone'), class: "text-xs font-bold text-slate-500 uppercase tracking-widest" %>
            <%= f.text_field :phone, required: true, placeholder: t('home.warranty.form.placeholder.phone'), class: "w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all" %>
          </div>
          <div class="space-y-2">
            <%= f.label :email, t('home.warranty.form.email'), class: "text-xs font-bold text-slate-500 uppercase tracking-widest" %>
            <%= f.email_field :email, required: true, placeholder: t('home.warranty.form.placeholder.email'), class: "w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all" %>
          </div>
        </div>

        <div class="pt-4">
          <%= f.submit t('home.warranty.form.submit'), class: "w-full py-4 bg-slate-900 hover:bg-slate-800 text-white rounded-2xl font-black tracking-tight transition-all shadow-xl shadow-slate-200" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
