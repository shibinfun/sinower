<div class="relative bg-slate-900 py-24 overflow-hidden">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-[10%] -right-[10%] w-[40%] h-[40%] bg-blue-600/10 rounded-full blur-[120px]"></div>
  </div>

  <div class="relative max-w-screen-xl mx-auto px-6 text-center">
    <div class="inline-flex items-center px-4 py-2 bg-blue-500/10 border border-blue-500/20 rounded-full text-blue-400 text-xs font-bold tracking-widest uppercase mb-8 backdrop-blur-sm">
      <%= t('home.warranty.subtitle') %>
    </div>
    <h1 class="text-5xl md:text-6xl font-black text-white tracking-tight mb-8">
      <%= t('home.warranty.hero_title_1') %> <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-cyan-300"><%= t('home.warranty.hero_title_2') %></span><%= t('home.warranty.hero_title_3') %>
    </h1>
    <p class="max-w-2xl mx-auto text-slate-400 text-lg font-medium">
      <%= t('home.warranty.hero_desc') %>
    </p>
  </div>
</div>

<div class="bg-white py-24">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-24">
      <% [
        { key: 'full', icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" },
        { key: 'core', icon: "M13 10V3L4 14h7v7l9-11h-7z" },
        { key: 'lifetime', icon: "M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" }
      ].each do |item| %>
        <div class="p-8 bg-slate-50 rounded-[2.5rem] border border-slate-100 hover:bg-white hover:shadow-2xl hover:shadow-blue-500/10 transition-all duration-500 group">
          <div class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-xl shadow-blue-600/20 group-hover:-translate-y-2 transition-transform duration-500">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="<%= item[:icon] %>"></path></svg>
          </div>
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-xl font-black text-slate-900 tracking-tight"><%= t("home.warranty.plans.#{item[:key]}.title") %></h3>
            <span class="text-[10px] font-black text-blue-600 bg-blue-50 px-2 py-1 rounded-lg uppercase tracking-widest"><%= t("home.warranty.plans.#{item[:key]}.period") %></span>
          </div>
          <p class="text-slate-500 font-medium leading-relaxed">
            <%= t("home.warranty.plans.#{item[:key]}.desc") %>
          </p>
        </div>
      <% end %>
    </div>

    <div class="max-w-4xl mx-auto space-y-16">
      <section>
        <h2 class="text-3xl font-black text-slate-900 mb-8 flex items-center">
          <span class="w-2 h-8 bg-blue-600 rounded-full mr-4"></span>
          <%= t('home.warranty.process.title') %>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 relative">
          <% [1, 2, 3, 4].each do |i| %>
            <div class="p-6 bg-slate-50 rounded-2xl border border-slate-100 relative z-10">
              <span class="text-4xl font-black text-blue-100 absolute top-4 right-4">0<%= i %></span>
              <h4 class="text-lg font-black text-slate-900 mb-2 relative z-10"><%= t("home.warranty.process.step#{i}.title") %></h4>
              <p class="text-xs text-slate-500 font-bold uppercase relative z-10"><%= t("home.warranty.process.step#{i}.desc") %></p>
            </div>
          <% end %>
        </div>
      </section>

      <section class="bg-slate-900 rounded-[3rem] p-12 text-white relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-blue-600 rounded-full blur-[100px] opacity-20"></div>
        <div class="relative z-10">
          <h2 class="text-3xl font-black mb-8"><%= t('home.warranty.exclusion_title') %></h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-slate-400 text-sm font-medium leading-relaxed">
            <ul class="space-y-4">
              <% %w[damage unauthorized].each do |key| %>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-red-500 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                  <%= t("home.warranty.exclusions.#{key}") %>
                </li>
              <% end %>
            </ul>
            <ul class="space-y-4">
              <% %w[force_majeure improper_use].each do |key| %>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-red-500 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                  <%= t("home.warranty.exclusions.#{key}") %>
                </li>
              <% end %>
            </ul>
          </div>
        </div>
      </section>
    </div>
  </div>
</div>
