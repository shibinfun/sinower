<div class="relative bg-slate-900 py-24 overflow-hidden">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-[10%] -right-[10%] w-[40%] h-[40%] bg-blue-600/10 rounded-full blur-[120px]"></div>
  </div>

  <div class="relative max-w-screen-xl mx-auto px-6 text-center">
    <div class="inline-flex items-center px-4 py-2 bg-blue-500/10 border border-blue-500/20 rounded-full text-blue-400 text-xs font-bold tracking-widest uppercase mb-8 backdrop-blur-sm">
      <%= t('home.warranty.subtitle') %>
    </div>
    <h1 class="text-5xl md:text-6xl font-black text-white tracking-tight mb-8">
      <%= t('home.warranty.hero_title_1') %> <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-cyan-300"><%= t('home.warranty.hero_title_2') %></span><%= t('home.warranty.hero_title_3') %>
    </h1>
    <p class="max-w-2xl mx-auto text-slate-400 text-lg font-medium mb-12">
      <%= t('home.warranty.hero_desc') %>
    </p>

    <!-- 产品类别下载与反馈框 -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto" x-data="{ openModal: false, productType: '' }">
      <% [
        { key: 'refrigeration', color: 'blue' },
        { key: 'cooking', color: 'orange' },
        { key: 'stainless', color: 'slate' }
      ].each do |item| %>
        <div class="bg-white/5 backdrop-blur-md border border-white/10 rounded-3xl p-8 flex flex-col items-center text-center group hover:bg-white/10 transition-all duration-500">
          <h3 class="text-xl font-bold text-white mb-8"><%= t("home.warranty.product_lines.#{item[:key]}") %></h3>
          <div class="space-y-4 w-full">
            <%= link_to asset_path('creatical.pdf'), class: "w-full py-3 bg-white/10 hover:bg-white/20 text-white rounded-xl font-bold text-sm transition-colors flex items-center justify-center space-x-2", download: "Warranty_Terms_#{item[:key]}.pdf" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
              <span><%= t('home.warranty.download_terms') %></span>
            <% end %>
            <button @click="openModal = true; productType = '<%= t("home.warranty.product_lines.#{item[:key]}") %>'" class="w-full py-3 bg-blue-600 hover:bg-blue-500 text-white rounded-xl font-bold text-sm transition-all shadow-lg shadow-blue-600/20 flex items-center justify-center space-x-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"></path></svg>
              <span><%= t('home.warranty.feedback_btn') %></span>
            </button>
          </div>
        </div>
      <% end %>

      <!-- 反馈表单弹窗 -->
      <div x-show="openModal" 
           x-transition:enter="transition ease-out duration-300"
           x-transition:enter-start="opacity-0 scale-95"
           x-transition:enter-end="opacity-100 scale-100"
           x-transition:leave="transition ease-in duration-200"
           x-transition:leave-start="opacity-100 scale-100"
           x-transition:leave-end="opacity-0 scale-95"
           class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-slate-900/80 backdrop-blur-sm"
           x-cloak>
        <div class="bg-white rounded-[2rem] w-full max-w-2xl overflow-hidden shadow-2xl relative" @click.away="openModal = false">
          <div class="p-8 border-b border-slate-100 flex items-center justify-between bg-slate-50">
            <h3 class="text-2xl font-black text-slate-900 tracking-tight" x-text="'<%= t('home.warranty.feedback_btn') %>: ' + productType"></h3>
            <button @click="openModal = false" class="text-slate-400 hover:text-slate-600">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
          </div>
          
          <%= form_with model: @warranty_inquiry, url: warranty_inquiry_path, class: "p-8 space-y-6 max-h-[70vh] overflow-y-auto" do |f| %>
            <%= f.hidden_field :product_type, ":value": "productType" %>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <%= f.label :subject, t('home.warranty.form.subject'), class: "text-xs font-bold text-slate-500 uppercase tracking-widest" %>
                <%= f.text_field :subject, required: true, placeholder: t('home.warranty.form.placeholder.subject'), class: "w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all" %>
              </div>
              <div class="space-y-2">
                <%= f.label :model_number, t('home.warranty.form.model_number'), class: "text-xs font-bold text-slate-500 uppercase tracking-widest" %>
                <%= f.text_field :model_number, required: true, placeholder: t('home.warranty.form.placeholder.model_number'), class: "w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all" %>
              </div>
            </div>

            <div class="space-y-2">
              <%= f.label :description, t('home.warranty.form.description'), class: "text-xs font-bold text-slate-500 uppercase tracking-widest" %>
              <%= f.text_area :description, rows: 4, required: true, placeholder: t('home.warranty.form.placeholder.description'), class: "w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all resize-none" %>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              <div class="space-y-2">
                <%= f.label :name, t('home.warranty.form.name'), class: "text-xs font-bold text-slate-500 uppercase tracking-widest" %>
                <%= f.text_field :name, required: true, placeholder: t('home.warranty.form.placeholder.name'), class: "w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all" %>
              </div>
              <div class="space-y-2">
                <%= f.label :phone, t('home.warranty.form.phone'), class: "text-xs font-bold text-slate-500 uppercase tracking-widest" %>
                <%= f.text_field :phone, required: true, placeholder: t('home.warranty.form.placeholder.phone'), class: "w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all" %>
              </div>
              <div class="space-y-2">
                <%= f.label :email, t('home.warranty.form.email'), class: "text-xs font-bold text-slate-500 uppercase tracking-widest" %>
                <%= f.email_field :email, required: true, placeholder: t('home.warranty.form.placeholder.email'), class: "w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all" %>
              </div>
            </div>

            <div class="pt-4">
              <%= f.submit t('home.warranty.form.submit'), class: "w-full py-4 bg-slate-900 hover:bg-slate-800 text-white rounded-2xl font-black tracking-tight transition-all shadow-xl shadow-slate-200" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="bg-white py-24">
  <div class="max-w-screen-xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-24">
      <% [
        { key: 'full', icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" },
        { key: 'core', icon: "M13 10V3L4 14h7v7l9-11h-7z" },
        { key: 'lifetime', icon: "M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" }
      ].each do |item| %>
        <div class="p-8 bg-slate-50 rounded-[2.5rem] border border-slate-100 hover:bg-white hover:shadow-2xl hover:shadow-blue-500/10 transition-all duration-500 group">
          <div class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-xl shadow-blue-600/20 group-hover:-translate-y-2 transition-transform duration-500">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="<%= item[:icon] %>"></path></svg>
          </div>
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-xl font-black text-slate-900 tracking-tight"><%= t("home.warranty.plans.#{item[:key]}.title") %></h3>
            <span class="text-[10px] font-black text-blue-600 bg-blue-50 px-2 py-1 rounded-lg uppercase tracking-widest"><%= t("home.warranty.plans.#{item[:key]}.period") %></span>
          </div>
          <p class="text-slate-500 font-medium leading-relaxed">
            <%= t("home.warranty.plans.#{item[:key]}.desc") %>
          </p>
        </div>
      <% end %>
    </div>

    <div class="max-w-4xl mx-auto space-y-16">
      <section>
        <h2 class="text-3xl font-black text-slate-900 mb-8 flex items-center">
          <span class="w-2 h-8 bg-blue-600 rounded-full mr-4"></span>
          <%= t('home.warranty.process.title') %>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 relative">
          <% [1, 2, 3, 4].each do |i| %>
            <div class="p-6 bg-slate-50 rounded-2xl border border-slate-100 relative z-10">
              <span class="text-4xl font-black text-blue-100 absolute top-4 right-4">0<%= i %></span>
              <h4 class="text-lg font-black text-slate-900 mb-2 relative z-10"><%= t("home.warranty.process.step#{i}.title") %></h4>
              <p class="text-xs text-slate-500 font-bold uppercase relative z-10"><%= t("home.warranty.process.step#{i}.desc") %></p>
            </div>
          <% end %>
        </div>
      </section>

      <section class="bg-slate-900 rounded-[3rem] p-12 text-white relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-blue-600 rounded-full blur-[100px] opacity-20"></div>
        <div class="relative z-10">
          <h2 class="text-3xl font-black mb-8"><%= t('home.warranty.exclusion_title') %></h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-slate-400 text-sm font-medium leading-relaxed">
            <ul class="space-y-4">
              <% %w[damage unauthorized].each do |key| %>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-red-500 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                  <%= t("home.warranty.exclusions.#{key}") %>
                </li>
              <% end %>
            </ul>
            <ul class="space-y-4">
              <% %w[force_majeure improper_use].each do |key| %>
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-red-500 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                  <%= t("home.warranty.exclusions.#{key}") %>
                </li>
              <% end %>
            </ul>
          </div>
        </div>
      </section>
    </div>
  </div>
</div>
