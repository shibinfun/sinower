<% 
  content_for :title, "#{@sku.name} - #{t('home.index.hero_title_2')}"
  content_for :meta_description, "#{@sku.name} (#{@sku.category.localized_name}): #{t('home.about.product_lines.refrigeration_desc') if @sku.category.category_kind == 'a'} #{t('home.about.product_lines.cooking_desc') if @sku.category.category_kind == 'b'} #{t('home.about.product_lines.stainless_desc') if @sku.category.category_kind == 'c'}"
  content_for :meta_keywords, "#{@sku.name}, #{@sku.category.localized_name}, Sinower, commercial kitchen equipment"
%>
<div class="max-w-screen-xl mx-auto px-4 py-12">
  <!-- 顶部面包屑导航 -->
  <nav class="flex mb-10 items-center space-x-2 text-sm font-bold bg-white/50 backdrop-blur-sm p-3 rounded-xl border border-slate-200/50 w-fit sticky top-20 z-10">
    <%= link_to categories_path, class: "text-slate-400 hover:text-blue-600 transition-colors" do %>
      <%= t('categories.all_products', default: '全部产品') %>
    <% end %>
    <svg class="w-4 h-4 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
    <% @sku.category.ancestors_and_self.each do |cat| %>
      <%= link_to cat.localized_name, categories_path(category_id: cat.id), class: "text-slate-400 hover:text-blue-600 transition-colors" %>
      <svg class="w-4 h-4 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
    <% end %>
    <span class="text-slate-900 truncate max-w-[200px]"><%= @sku.name %></span>
  </nav>

  <!-- 产品主展示区：左右布局 -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 bg-white p-6 lg:p-12 rounded-[2.5rem] border border-slate-100 shadow-2xl shadow-blue-500/5 overflow-hidden relative">
    <!-- 装饰背景 -->
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-blue-50 rounded-full blur-3xl opacity-50 -z-0"></div>
    
    <!-- 左侧：媒体展示 (占 5/12) -->
    <div class="lg:col-span-5 relative z-10 space-y-8" x-data="{ 
      activeImage: 0, 
      isZoomed: false, 
      bgPosX: 0, 
      bgPosY: 0,
      handleZoom(e) {
        const container = e.currentTarget;
        const { left, top, width, height } = container.getBoundingClientRect();
        const x = e.clientX - left;
        const y = e.clientY - top;
        
        if (x < 0 || y < 0 || x > width || y > height) {
          this.isZoomed = false;
          return;
        }

        this.isZoomed = true;
        this.bgPosX = (x / width) * 100;
        this.bgPosY = (y / height) * 100;
      }
    }">
      <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-2xl overflow-hidden group relative">
        <div class="aspect-square relative overflow-hidden bg-slate-50 cursor-zoom-in"
             @mousemove="handleZoom"
             @mouseleave="isZoomed = false"
             @touchstart="isZoomed = false">
          <% if @sku.images.attached? %>
            <% @sku.sorted_images.each_with_index do |image, index| %>
              <div x-show="activeImage === <%= index %>" 
                   x-cloak
                   x-transition:enter="transition ease-out duration-500"
                   x-transition:enter-start="opacity-0 transform scale-95"
                   x-transition:enter-end="opacity-100 transform scale-100"
                   class="w-full h-full absolute inset-0">
                <% begin %>
                  <% variant_url = url_for(image.variant(resize_to_limit: [1200, 1200], saver: { quality: 90 })) %>
                  <%= image_tag variant_url, 
                                class: "w-full h-full object-contain p-4 transition-transform duration-200 ease-out origin-center", 
                                style: "background-color: transparent;",
                                ":style": "isZoomed ? `transform: scale(2.5); transform-origin: ${bgPosX}% ${bgPosY}%` : 'transform: scale(1); transform-origin: center;'" %>
                <% rescue ArgumentError, ActiveStorage::InvariableError %>
                  <%= image_tag image, class: "w-full h-full object-contain p-4 group-hover:scale-105 transition-transform duration-1000 ease-in-out", style: "background-color: transparent;" %>
                <% end %>
              </div>
            <% end %>
          <% else %>
            <div class="w-full h-full flex flex-col items-center justify-center bg-gradient-to-br from-slate-50 to-slate-100">
              <svg class="w-32 h-32 text-slate-200 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
              <span class="text-xs font-black text-slate-300 uppercase tracking-widest">Digital Asset Pending</span>
            </div>
          <% end %>
          
          <div class="absolute top-6 left-6 flex flex-col space-y-2">
            <span class="bg-blue-600 text-white px-4 py-1.5 rounded-full text-[10px] font-black tracking-widest uppercase shadow-lg shadow-blue-500/30">
              <%= t('skus.pro_series') %>
            </span>
          </div>
        </div>
      </div>

      <!-- 缩略图列表 -->
      <% if @sku.images.attached? && @sku.images.count > 1 %>
        <div class="flex flex-wrap gap-4 px-2">
          <% @sku.sorted_images.each_with_index do |image, index| %>
            <button @click="activeImage = <%= index %>" 
                    :class="activeImage === <%= index %> ? 'ring-2 ring-blue-600 border-transparent shadow-lg' : 'border-slate-100 hover:border-blue-300'"
                    class="w-20 h-20 rounded-2xl border-2 bg-white overflow-hidden transition-all duration-300 group">
              <% begin %>
                <%= image_tag image.variant(resize_to_limit: [200, 200], saver: { quality: 80 }), class: "w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" %>
              <% rescue ArgumentError, ActiveStorage::InvariableError %>
                <div class="w-full h-full bg-red-50 flex items-center justify-center text-red-400 text-xs">无法预览</div>
              <% end %>
            </button>
          <% end %>
        </div>
      <% end %>
      
    </div>

    <!-- 右侧：产品详情信息 (占 7/12) -->
    <div class="lg:col-span-7 flex flex-col relative z-10 py-4">
      <div class="mb-10">
        <div class="flex items-center space-x-3 mb-6">
          <span class="h-1 w-12 bg-blue-600 rounded-full"></span>
          <span class="text-[10px] font-black text-blue-600 uppercase tracking-[0.3em]">Technical Excellence</span>
        </div>
        
        <h1 class="text-5xl font-black text-slate-900 mb-6 tracking-tight leading-none"><%= @sku.name %></h1>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
        <% if @sku.category.category_kind == 'a' %>
          <% [
            { label: t('skus.net_capacity'), value: @sku.skuable.net_capacity, sub: "Net Capacity" },
            { label: t('skus.temp_range'), value: @sku.skuable.temp_range, sub: "Temp Range", highlight: true },
            { label: t('skus.dimensions'), value: @sku.skuable.unit_dimensions, sub: "Unit Dimensions" },
            { label: t('skus.voltage'), value: @sku.skuable.voltage_frequency, sub: "Power Supply" }
          ].each do |spec| %>
            <div class="group">
              <div class="flex flex-col border-l-2 border-slate-100 pl-6 group-hover:border-blue-600 transition-all duration-300">
                <span class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1"><%= spec[:label] %></span>
                <span class="text-xl font-black <%= spec[:highlight] ? 'text-blue-600' : 'text-slate-900' %> tracking-tight"><%= spec[:value] %></span>
              </div>
            </div>
          <% end %>
        <% elsif @sku.category.category_kind == 'b' %>
          <% [
            { label: t('skus.burners_control'), value: @sku.skuable.burners_and_control_method, sub: "Burners & Control" },
            { label: t('skus.gas_type'), value: @sku.skuable.gas_type, sub: "Gas Type" },
            { label: t('skus.intake_pressure'), value: @sku.skuable.intake_tube_pressure, sub: "Intake Pressure" },
            { label: t('skus.btu_per_burner'), value: @sku.skuable.per_btu, sub: "BTU Per Burner" },
            { label: t('skus.total_btu'), value: @sku.skuable.total_btu, sub: "Total BTU", highlight: true },
            { label: t('skus.regulator'), value: @sku.skuable.regulator, sub: "Regulator" },
            { label: t('skus.work_area'), value: @sku.skuable.work_area, sub: "Work Area" },
            { label: t('skus.dimensions'), value: @sku.skuable.exterior_dimensions, sub: "Exterior Dimensions" }
          ].select { |s| s[:value].present? }.each do |spec| %>
            <div class="group">
              <div class="flex flex-col border-l-2 border-slate-100 pl-6 group-hover:border-blue-600 transition-all duration-300">
                <span class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1"><%= spec[:label] %></span>
                <span class="text-xl font-black <%= spec[:highlight] ? 'text-blue-600' : 'text-slate-900' %> tracking-tight"><%= spec[:value] %></span>
              </div>
            </div>
          <% end %>
        <% elsif @sku.category.category_kind == 'c' %>
          <% [
            { label: t('skus.dimensions'), value: @sku.skuable.unit_dimensions, sub: "Unit Dimensions" },
            { label: t('skus.product_dimensions'), value: @sku.skuable.product_dimensions, sub: "Product Dimensions" },
            { label: t('skus.bowl_dimensions'), value: @sku.skuable.sink_bowl_dimensions, sub: "Bowl Dimensions" },
            { label: t('skus.sink_depth'), value: @sku.skuable.sink_depth, sub: "Sink Depth" },
            { label: t('skus.leg_bracing'), value: @sku.skuable.leg_bracing, sub: "Leg Bracing" },
            { label: t('skus.faucet_drain'), value: @sku.skuable.faucet_and_drain, sub: "Faucet & Drain" }
          ].select { |s| s[:value].present? }.each do |spec| %>
            <div class="group">
              <div class="flex flex-col border-l-2 border-slate-100 pl-6 group-hover:border-blue-600 transition-all duration-300">
                <span class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1"><%= spec[:label] %></span>
                <span class="text-xl font-black text-slate-900 tracking-tight"><%= spec[:value] %></span>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="group">
            <div class="flex flex-col border-l-2 border-slate-100 pl-6 group-hover:border-blue-600 transition-all duration-300">
              <span class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1"><%= t('skus.dimensions') %></span>
              <span class="text-xl font-black text-slate-900 tracking-tight"><%= @sku.skuable.unit_dimensions %></span>
            </div>
          </div>
        <% end %>
      </div>

      <!-- 操作区域 -->
      <div class="mt-auto space-y-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="sm:col-span-2">
            <%= link_to contact_path, class: "w-full inline-flex justify-center items-center px-10 py-5 bg-blue-600 hover:bg-blue-700 text-white rounded-[1.5rem] font-black text-sm tracking-widest uppercase transition-all duration-300 shadow-2xl shadow-blue-500/30 group" do %>
              <span><%= t('skus.get_quote') %></span>
              <svg class="w-5 h-5 ml-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            <% end %>
          </div>
          
          <% if @sku.manual.attached? %>
            <%= link_to rails_blob_path(@sku.manual, disposition: "attachment"), 
                        class: "inline-flex justify-center items-center px-6 py-4 bg-slate-900 hover:bg-black text-white rounded-[1.25rem] font-black text-xs tracking-widest uppercase transition-all duration-300 text-center" do %>
              <%= t('skus.download_manual') %>
            <% end %>
          <% else %>
            <div class="inline-flex justify-center items-center px-6 py-4 bg-slate-200 text-slate-400 rounded-[1.25rem] font-black text-xs tracking-widest uppercase cursor-not-allowed text-center">
              <%= t('skus.manual_preparing') %>
            </div>
          <% end %>

          <% if @sku.spec_sheet.attached? %>
            <%= link_to rails_blob_path(@sku.spec_sheet, disposition: "attachment"), 
                        class: "inline-flex justify-center items-center px-6 py-4 bg-slate-100 hover:bg-slate-200 text-slate-900 rounded-[1.25rem] font-black text-xs tracking-widest uppercase transition-all duration-300 text-center" do %>
              <%= t('skus.download_spec_sheet') %>
            <% end %>
          <% else %>
            <div class="inline-flex justify-center items-center px-6 py-4 bg-slate-100 text-slate-300 rounded-[1.25rem] font-black text-xs tracking-widest uppercase cursor-not-allowed text-center">
              <%= t('skus.spec_sheet_preparing') %>
            </div>
          <% end %>
        </div>
        <p class="text-[9px] text-slate-400 text-center sm:text-left font-bold uppercase tracking-tighter">
          <%= t('skus.spec_notice') %>
        </p>
      </div>
    </div>
  </div>

  <!-- 下方：详细特性 -->
  <div class="mt-12 grid grid-cols-1 lg:grid-cols-3 gap-12">
    <div class="lg:col-span-2">
      <div class="bg-white rounded-[2rem] p-10 border border-slate-100 shadow-xl h-full">
        <div class="flex items-center space-x-4 mb-8">
          <h3 class="text-xl font-black text-slate-900 tracking-tight"><%= t('skus.core_features') %></h3>
        </div>
        <div class="bg-slate-50 rounded-2xl p-8 text-slate-600 text-base leading-relaxed font-medium border border-slate-100 prose prose-slate max-w-none">
          <% 
            features = if I18n.locale.to_s.start_with?('zh')
              @sku.skuable.standard_features_zh.presence || @sku.skuable.standard_features
            else
              @sku.skuable.standard_features
            end
          %>
          <% if features.present? %>
            <%= features %>
          <% else %>
            <%= t('skus.default_feature_desc') %>
          <% end %>
        </div>
      </div>
    </div>
    
    <div class="lg:col-span-1">
      <div class="bg-slate-900 rounded-[2rem] p-10 text-white h-full relative overflow-hidden">
        <!-- 装饰性元素 -->
        <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-blue-600 rounded-full blur-3xl opacity-20"></div>
        
        <h3 class="text-xl font-black mb-6 tracking-tight relative z-10"><%= t('skus.need_more_info') %></h3>
        <p class="text-slate-400 text-sm mb-8 leading-relaxed relative z-10">
          <% if @sku.category.category_kind == 'c' %>
            <%= t('skus.stainless_help') %>
          <% elsif @sku.category.category_kind == 'b' %>
            <%= t('skus.cooking_help') %>
          <% else %>
            <%= t('skus.refrigeration_help') %>
          <% end %>
        </p>
        
        <ul class="space-y-4 relative z-10 mb-8">
          <li class="flex items-center text-xs font-bold text-blue-400">
            <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <%= t('skus.support_24_7') %>
          </li>
          <li class="flex items-center text-xs font-bold text-blue-400">
            <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <%= t('skus.warranty_coverage') %>
          </li>
          <li class="flex items-center text-xs font-bold text-blue-400">
            <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            <%= t('skus.spare_parts') %>
          </li>
        </ul>
        
        <%= link_to t('skus.contact_now'), contact_path, class: "inline-block w-full text-center py-4 bg-white text-slate-900 rounded-xl font-black text-xs tracking-widest uppercase hover:bg-blue-50 transition-colors relative z-10" %>
      </div>
    </div>
  </div>
</div>
