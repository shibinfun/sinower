<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-slate-800">数据统计</h1>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-white rounded-xl shadow-sm p-6 border border-slate-100">
      <div class="text-sm font-medium text-slate-500 mb-1">总浏览量 (PV)</div>
      <div class="text-3xl font-bold text-blue-600"><%= @total_visits %></div>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-6 border border-slate-100">
      <div class="text-sm font-medium text-slate-500 mb-1">独立访问者 (UV)</div>
      <div class="text-3xl font-bold text-emerald-600"><%= @unique_ips %></div>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-6 border border-slate-100">
      <div class="text-sm font-medium text-slate-500 mb-1">平均访客浏览</div>
      <div class="text-3xl font-bold text-amber-600">
        <%= @unique_ips > 0 ? (@total_visits.to_f / @unique_ips).round(2) : 0 %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
    <!-- 每日访问 -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
      <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50">
        <h2 class="font-semibold text-slate-800">最近 7 天访问量</h2>
      </div>
      <div class="p-6">
        <table class="min-w-full">
          <thead>
            <tr class="text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">
              <th class="pb-3">日期</th>
              <th class="pb-3 text-right">浏览量</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @daily_visits.each do |date, count| %>
              <tr>
                <td class="py-3 text-sm text-slate-600"><%= date %></td>
                <td class="py-3 text-sm text-slate-800 text-right font-medium"><%= count %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- 热门页面 -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
      <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50">
        <h2 class="font-semibold text-slate-800">热门访问页面 (Top 10)</h2>
      </div>
      <div class="p-6">
        <table class="min-w-full">
          <thead>
            <tr class="text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">
              <th class="pb-3">页面路径</th>
              <th class="pb-3 text-right">浏览量</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @top_pages.each do |path, count| %>
              <tr>
                <td class="py-3 text-sm text-slate-600 truncate max-w-[200px]" title="<%= path %>">
                  <%= path %>
                </td>
                <td class="py-3 text-sm text-slate-800 text-right font-medium"><%= count %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- 最近访问 -->
  <div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
    <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50">
      <h2 class="font-semibold text-slate-800">最近访问记录 (Top 50)</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-100">
        <thead class="bg-slate-50/50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">时间</th>
            <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">IP 地址</th>
            <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">页面</th>
            <th class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">User Agent</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-slate-100">
          <% @recent_visits.each do |log| %>
            <tr class="hover:bg-slate-50/50 transition-colors">
              <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600">
                <%= log.created_at.strftime("%Y-%m-%d %H:%M:%S") %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-800 font-mono">
                <%= log.remote_ip %>
              </td>
              <td class="px-6 py-4 text-sm text-blue-600">
                <%= log.path %>
              </td>
              <td class="px-6 py-4 text-xs text-slate-500 max-w-xs truncate" title="<%= log.user_agent %>">
                <%= log.user_agent %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
