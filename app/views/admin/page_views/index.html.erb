<% content_for :admin_title, "数据统计 - 访问分析" %>

<div class="space-y-6">
  <!-- 统计卡片 -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
    <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
      <div class="text-sm text-slate-500 mb-2">总访问量</div>
      <div class="text-3xl font-bold text-blue-600"><%= @stats[:total_views] %></div>
    </div>
    
    <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
      <div class="text-sm text-slate-500 mb-2">今日访问量</div>
      <div class="text-3xl font-bold text-green-600"><%= @stats[:today_views] %></div>
    </div>
    
    <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
      <div class="text-sm text-slate-500 mb-2">今日独立 IP</div>
      <div class="text-3xl font-bold text-purple-600"><%= @stats[:unique_ips_today] %></div>
    </div>
    
    <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
      <div class="text-sm text-slate-500 mb-2">平均停留时长</div>
      <div class="text-3xl font-bold text-orange-600"><%= PageView.new(duration: @stats[:avg_duration]).duration_formatted %></div>
    </div>
  </div>

  <!-- 筛选器 -->
  <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
    <%= form_with url: admin_page_views_path, method: :get, local: true, class: "grid grid-cols-1 md:grid-cols-5 gap-4" do |f| %>
      <div>
        <%= label_tag :page_type, "页面类型", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= select_tag :page_type, 
            options_for_select([['全部', ''], ['SKU', '1'], ['分类', '2'], ['首页', '3'], ['产品列表', '4']], @filter_params[:page_type]),
            class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
      </div>
      
      <div>
        <%= label_tag :ip, "IP 地址", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= text_field_tag :ip, @filter_params[:ip], placeholder: "192.168.1.1", class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
      </div>
      
      <div>
        <%= label_tag :city, "城市", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= text_field_tag :city, @filter_params[:city], placeholder: "Shanghai", class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
      </div>
      
      <div>
        <%= label_tag :date_from, "开始日期", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= date_field_tag :date_from, @filter_params[:date_from], class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
      </div>
      
      <div>
        <%= label_tag :date_to, "结束日期", class: "block text-sm font-medium text-slate-700 mb-2" %>
        <%= date_field_tag :date_to, @filter_params[:date_to], class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" %>
      </div>
      
      <div class="md:col-span-5 flex space-x-4">
        <%= submit_tag "筛选", class: "bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg font-medium transition-colors cursor-pointer" %>
        <%= link_to "重置", admin_page_views_path, class: "bg-slate-100 hover:bg-slate-200 text-slate-700 px-6 py-2 rounded-lg font-medium transition-colors" %>
      </div>
    <% end %>
  </div>

  <!-- 热门页面 TOP 10 -->
  <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
    <h3 class="text-lg font-bold text-slate-800 mb-4">🔥 热门页面 TOP 10</h3>
    <table class="min-w-full divide-y divide-slate-200">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">排名</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">页面名称</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">类型</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-slate-500 uppercase tracking-wider">浏览次数</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-slate-200">
        <% @stats[:top_pages].each_with_index do |page, index| %>
          <tr class="hover:bg-slate-50">
            <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-slate-900">#<%= index + 1 %></td>
            <td class="px-6 py-4 text-sm text-slate-700"><%= page.page_name || 'Unknown' %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500"><%= page.page_type.humanize %></td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-bold text-blue-600"><%= page.view_count %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- 热门地区 TOP 10 -->
  <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
    <h3 class="text-lg font-bold text-slate-800 mb-4">🌍 热门地区 TOP 10</h3>
    <table class="min-w-full divide-y divide-slate-200">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">排名</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">城市</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">省份/州</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">国家</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-slate-500 uppercase tracking-wider">浏览次数</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-slate-200">
        <% @stats[:top_locations].each_with_index do |location, index| %>
          <tr class="hover:bg-slate-50">
            <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-slate-900">#<%= index + 1 %></td>
            <td class="px-6 py-4 text-sm text-slate-700"><%= location.city || 'Unknown' %></td>
            <td class="px-6 py-4 text-sm text-slate-500"><%= location.province || '-' %></td>
            <td class="px-6 py-4 text-sm text-slate-500"><%= location.country || '-' %></td>
            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-bold text-green-600"><%= location.view_count %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- 详细记录 -->
  <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
    <h3 class="text-lg font-bold text-slate-800 mb-4">📊 详细访问记录</h3>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">时间</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">页面</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">IP / 位置</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">设备 / 浏览器</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">停留时长</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">来源</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-slate-200">
          <% @page_views.each do |pv| %>
            <tr class="hover:bg-slate-50">
              <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-700">
                <div class="font-medium"><%= pv.visited_at.strftime('%Y-%m-%d %H:%M') %></div>
                <div class="text-xs text-slate-500"><%= pv.visited_at.strftime('%H:%M:%S') %></div>
              </td>
              <td class="px-6 py-4 text-sm">
                <div class="font-medium text-slate-900"><%= pv.page_name %></div>
                <div class="text-xs text-slate-500"><%= pv.page_type.humanize %></div>
              </td>
              <td class="px-6 py-4 text-sm">
                <div class="font-mono text-xs text-slate-700"><%= pv.ip %></div>
                <div class="text-xs text-slate-500">
                  <%= [pv.city, pv.province, pv.country].compact.join(' · ') %>
                </div>
              </td>
              <td class="px-6 py-4 text-sm">
                <div class="text-xs text-slate-700">💻 <%= pv.device_type.capitalize %></div>
                <div class="text-xs text-slate-500"><%= pv.browser_name %> / <%= pv.os_name %></div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-blue-600">
                <%= pv.duration_formatted %>
              </td>
              <td class="px-6 py-4 text-sm text-slate-500 max-w-xs truncate">
                <%= pv.referer.present? ? pv.referer.gsub(/^https?:\/\//, '') : '-' %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    
    <% if @page_views.total_pages > 1 %>
      <div class="mt-6 flex justify-center">
        <%= paginate @page_views %>
      </div>
    <% end %>
  </div>
</div>
