<div class="min-h-screen bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-50">
  <div class="max-w-screen-2xl mx-auto px-6 py-12">
    <!-- Page Header -->
    <div class="mb-10">
      <h1 class="text-4xl font-black text-slate-900 mb-3 tracking-tight">📊 数据统计</h1>
      <p class="text-slate-600 text-lg">查看网站访问数据、用户行为和流量分析</p>
    </div>

    <!-- Period Filter -->
    <div class="bg-white rounded-2xl shadow-lg p-6 mb-8 border border-slate-100">
      <div class="flex items-center justify-between">
        <h2 class="text-lg font-bold text-slate-800">时间范围</h2>
        <div class="flex space-x-2">
          <%= link_to "今天", admin_statistics_path(period: 'today'), 
                      class: "px-4 py-2 rounded-lg font-semibold transition-all #{@period == 'today' ? 'bg-blue-600 text-white shadow-md' : 'bg-slate-100 text-slate-700 hover:bg-slate-200'}" %>
          <%= link_to "昨天", admin_statistics_path(period: 'yesterday'), 
                      class: "px-4 py-2 rounded-lg font-semibold transition-all #{@period == 'yesterday' ? 'bg-blue-600 text-white shadow-md' : 'bg-slate-100 text-slate-700 hover:bg-slate-200'}" %>
          <%= link_to "本周", admin_statistics_path(period: 'week'), 
                      class: "px-4 py-2 rounded-lg font-semibold transition-all #{@period == 'week' ? 'bg-blue-600 text-white shadow-md' : 'bg-slate-100 text-slate-700 hover:bg-slate-200'}" %>
          <%= link_to "本月", admin_statistics_path(period: 'month'), 
                      class: "px-4 py-2 rounded-lg font-semibold transition-all #{@period == 'month' ? 'bg-blue-600 text-white shadow-md' : 'bg-slate-100 text-slate-700 hover:bg-slate-200'}" %>
          <%= link_to "全年", admin_statistics_path(period: 'year'), 
                      class: "px-4 py-2 rounded-lg font-semibold transition-all #{@period == 'year' ? 'bg-blue-600 text-white shadow-md' : 'bg-slate-100 text-slate-700 hover:bg-slate-200'}" %>
          <%= link_to "全部", admin_statistics_path(period: 'all'), 
                      class: "px-4 py-2 rounded-lg font-semibold transition-all #{@period == 'all' ? 'bg-blue-600 text-white shadow-md' : 'bg-slate-100 text-slate-700 hover:bg-slate-200'}" %>
        </div>
      </div>
    </div>

    <!-- Overview Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div class="bg-gradient-to-br from-blue-500 to-blue-600 rounded-2xl p-6 text-white shadow-xl">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-blue-100 font-semibold text-sm uppercase tracking-wide">总访问量</h3>
          <svg class="w-8 h-8 text-blue-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
          </svg>
        </div>
        <p class="text-4xl font-black mb-2"><%= @total_visits %></p>
        <p class="text-blue-100 text-sm">选定时间段内的页面浏览总数</p>
      </div>

      <div class="bg-gradient-to-br from-purple-500 to-purple-600 rounded-2xl p-6 text-white shadow-xl">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-purple-100 font-semibold text-sm uppercase tracking-wide">独立访客</h3>
          <svg class="w-8 h-8 text-purple-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
          </svg>
        </div>
        <p class="text-4xl font-black mb-2"><%= @unique_visitors %></p>
        <p class="text-purple-100 text-sm">基于独立IP地址计算</p>
      </div>

      <div class="bg-gradient-to-br from-green-500 to-green-600 rounded-2xl p-6 text-white shadow-xl">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-green-100 font-semibold text-sm uppercase tracking-wide">人均浏览</h3>
          <svg class="w-8 h-8 text-green-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
          </svg>
        </div>
        <p class="text-4xl font-black mb-2"><%= @avg_views_per_visitor %></p>
        <p class="text-green-100 text-sm">平均每个访客浏览的页面数</p>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
      <!-- Page Statistics -->
      <div class="bg-white rounded-2xl shadow-lg p-6 border border-slate-100">
        <h3 class="text-xl font-black text-slate-900 mb-6 flex items-center">
          <svg class="w-6 h-6 mr-2 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
          </svg>
          热门页面 TOP 20
        </h3>
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-slate-200">
                <th class="text-left py-3 px-4 text-sm font-bold text-slate-600">排名</th>
                <th class="text-left py-3 px-4 text-sm font-bold text-slate-600">页面</th>
                <th class="text-right py-3 px-4 text-sm font-bold text-slate-600">浏览量</th>
              </tr>
            </thead>
            <tbody>
              <% @page_stats.each_with_index do |stat, index| %>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="py-3 px-4">
                    <span class="inline-flex items-center justify-center w-8 h-8 rounded-full font-bold text-sm
                      <%= 'bg-yellow-100 text-yellow-700' if index == 0 %>
                      <%= 'bg-gray-100 text-gray-700' if index == 1 %>
                      <%= 'bg-orange-100 text-orange-700' if index == 2 %>
                      <%= 'bg-slate-100 text-slate-600' if index > 2 %>">
                      <%= index + 1 %>
                    </span>
                  </td>
                  <td class="py-3 px-4">
                    <div class="flex flex-col">
                      <span class="text-sm font-semibold text-slate-900 truncate max-w-xs"><%= stat.page_name || 'Unknown' %></span>
                      <%= link_to admin_statistics_show_path(url: stat.page_url), class: "text-xs text-blue-600 hover:underline truncate max-w-xs" do %>
                        <%= stat.page_url %>
                      <% end %>
                    </div>
                  </td>
                  <td class="text-right py-3 px-4">
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-bold bg-blue-100 text-blue-700">
                      <%= stat.views %>
                    </span>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Country Statistics -->
      <div class="bg-white rounded-2xl shadow-lg p-6 border border-slate-100">
        <h3 class="text-xl font-black text-slate-900 mb-6 flex items-center">
          <svg class="w-6 h-6 mr-2 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          国家/地区分布
        </h3>
        <div class="space-y-3">
          <% @country_stats.each do |stat| %>
            <div class="flex items-center justify-between p-3 bg-slate-50 rounded-lg hover:bg-slate-100 transition-colors">
              <div class="flex items-center space-x-3">
                <span class="text-2xl"><%= flag_emoji(stat.country) %></span>
                <span class="font-semibold text-slate-800"><%= stat.country || '未知' %></span>
              </div>
              <span class="px-3 py-1 bg-purple-100 text-purple-700 rounded-full text-sm font-bold">
                <%= stat.visits %> 次访问
              </span>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- City Statistics -->
    <div class="bg-white rounded-2xl shadow-lg p-6 mb-8 border border-slate-100">
      <h3 class="text-xl font-black text-slate-900 mb-6 flex items-center">
        <svg class="w-6 h-6 mr-2 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
        城市分布 TOP 15
      </h3>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="border-b border-slate-200">
              <th class="text-left py-3 px-4 text-sm font-bold text-slate-600">国家</th>
              <th class="text-left py-3 px-4 text-sm font-bold text-slate-600">省份/州</th>
              <th class="text-left py-3 px-4 text-sm font-bold text-slate-600">城市</th>
              <th class="text-right py-3 px-4 text-sm font-bold text-slate-600">访问量</th>
            </tr>
          </thead>
          <tbody>
            <% @city_stats.each do |stat| %>
              <tr class="hover:bg-slate-50 transition-colors">
                <td class="py-3 px-4 text-sm font-medium text-slate-800">
                  <%= flag_emoji(stat.country) %> <%= stat.country || '未知' %>
                </td>
                <td class="py-3 px-4 text-sm text-slate-600"><%= stat.region || '-' %></td>
                <td class="py-3 px-4 text-sm text-slate-600"><%= stat.city || '未知' %></td>
                <td class="text-right py-3 px-4">
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-bold bg-green-100 text-green-700">
                    <%= stat.visits %>
                  </span>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Recent Visits Table -->
    <div class="bg-white rounded-2xl shadow-lg p-6 border border-slate-100">
      <h3 class="text-xl font-black text-slate-900 mb-6 flex items-center">
        <svg class="w-6 h-6 mr-2 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        最近访问记录 (最新 50 条)
      </h3>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="border-b border-slate-200">
              <th class="text-left py-3 px-4 text-sm font-bold text-slate-600">访问时间</th>
              <th class="text-left py-3 px-4 text-sm font-bold text-slate-600">IP 地址</th>
              <th class="text-left py-3 px-4 text-sm font-bold text-slate-600">地理位置</th>
              <th class="text-left py-3 px-4 text-sm font-bold text-slate-600">页面</th>
              <th class="text-left py-3 px-4 text-sm font-bold text-slate-600">来源</th>
            </tr>
          </thead>
          <tbody>
            <% @recent_visits.each do |visit| %>
              <tr class="hover:bg-slate-50 transition-colors border-b border-slate-100">
                <td class="py-3 px-4 text-sm">
                  <div class="flex flex-col">
                    <span class="font-medium text-slate-900"><%= visit.visited_at.strftime('%Y-%m-%d') %></span>
                    <span class="text-slate-500 text-xs"><%= visit.visited_at.strftime('%H:%M:%S') %></span>
                  </div>
                </td>
                <td class="py-3 px-4">
                  <code class="text-xs bg-slate-100 px-2 py-1 rounded text-slate-700"><%= visit.ip_address %></code>
                </td>
                <td class="py-3 px-4 text-sm">
                  <% if visit.city.present? || visit.country.present? %>
                    <div class="flex items-center space-x-1">
                      <span><%= flag_emoji(visit.country) %></span>
                      <span class="text-slate-700"><%= [visit.city, visit.region, visit.country].compact.join(', ') %></span>
                    </div>
                  <% else %>
                    <span class="text-slate-400 text-xs">未知</span>
                  <% end %>
                </td>
                <td class="py-3 px-4">
                  <div class="flex flex-col">
                    <span class="text-sm font-medium text-slate-900 truncate max-w-xs"><%= visit.page_name || 'Unknown' %></span>
                    <span class="text-xs text-blue-600 truncate max-w-xs"><%= visit.page_url %></span>
                  </div>
                </td>
                <td class="py-3 px-4 text-sm">
                  <% if visit.referer.present? %>
                    <a href="<%= visit.referer %>" target="_blank" class="text-xs text-blue-600 hover:underline truncate max-w-xs block">
                      <%= truncate(visit.referer, length: 40) %>
                    </a>
                  <% else %>
                    <span class="text-slate-400 text-xs">直接访问</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%# Helper method for flag emoji %>
<% def flag_emoji(country_code)
   return '🌍' if country_code.blank?
   
   flags = {
     'US' => '🇺🇸', 'CN' => '🇨🇳', 'GB' => '🇬🇧', 'DE' => '🇩🇪', 'FR' => '🇫🇷',
     'JP' => '🇯🇵', 'KR' => '🇰🇷', 'IN' => '🇮🇳', 'BR' => '🇧🇷', 'CA' => '🇨🇦',
     'AU' => '🇦🇺', 'IT' => '🇮🇹', 'ES' => '🇪🇸', 'MX' => '🇲🇽', 'RU' => '🇷🇺'
   }
   
   flags[country_code.upcase] || '🌍'
 end %>
