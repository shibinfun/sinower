<div class="min-h-screen bg-gradient-to-br from-slate-50 via-blue-50 to-indigo-50">
  <div class="max-w-screen-xl mx-auto px-6 py-12">
    <!-- Back Button -->
    <div class="mb-8">
      <%= link_to admin_statistics_path, class: "inline-flex items-center text-blue-600 hover:text-blue-700 font-semibold" do %>
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        返回统计概览
      <% end %>
    </div>

    <!-- Page Header -->
    <div class="bg-white rounded-2xl shadow-lg p-8 mb-8 border border-slate-100">
      <h1 class="text-3xl font-black text-slate-900 mb-4">📄 页面详情</h1>
      <div class="space-y-2">
        <p class="text-lg text-slate-700 font-semibold"><%= @visit&.page_name || 'Unknown' %></p>
        <p class="text-blue-600"><%= @page_url %></p>
      </div>
      
      <div class="grid grid-cols-2 gap-6 mt-6 pt-6 border-t border-slate-200">
        <div>
          <p class="text-sm text-slate-500 mb-1">总浏览量</p>
          <p class="text-3xl font-black text-blue-600"><%= @page_stats %></p>
        </div>
        <div>
          <p class="text-sm text-slate-500 mb-1">独立访客数</p>
          <p class="text-3xl font-black text-purple-600"><%= @unique_ips %></p>
        </div>
      </div>
    </div>

    <!-- Visit Details Table -->
    <div class="bg-white rounded-2xl shadow-lg p-6 border border-slate-100">
      <h3 class="text-xl font-black text-slate-900 mb-6">访问记录明细</h3>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="border-b border-slate-200">
              <th class="text-left py-3 px-4 text-sm font-bold text-slate-600">访问时间</th>
              <th class="text-left py-3 px-4 text-sm font-bold text-slate-600">IP 地址</th>
              <th class="text-left py-3 px-4 text-sm font-bold text-slate-600">地理位置</th>
              <th class="text-left py-3 px-4 text-sm font-bold text-slate-600">ISP</th>
              <th class="text-left py-3 px-4 text-sm font-bold text-slate-600">User Agent</th>
              <th class="text-left py-3 px-4 text-sm font-bold text-slate-600">来源</th>
            </tr>
          </thead>
          <tbody>
            <% @visits.each do |visit| %>
              <tr class="hover:bg-slate-50 transition-colors border-b border-slate-100">
                <td class="py-3 px-4 text-sm">
                  <div class="flex flex-col">
                    <span class="font-medium text-slate-900"><%= visit.visited_at.strftime('%Y-%m-%d') %></span>
                    <span class="text-slate-500 text-xs"><%= visit.visited_at.strftime('%H:%M:%S') %></span>
                  </div>
                </td>
                <td class="py-3 px-4">
                  <code class="text-xs bg-slate-100 px-2 py-1 rounded text-slate-700"><%= visit.ip_address %></code>
                </td>
                <td class="py-3 px-4 text-sm">
                  <% if visit.city.present? || visit.country.present? %>
                    <div class="flex items-center space-x-1">
                      <span><%= flag_emoji(visit.country) %></span>
                      <span class="text-slate-700"><%= [visit.city, visit.region, visit.country].compact.join(', ') %></span>
                    </div>
                  <% else %>
                    <span class="text-slate-400 text-xs">未知</span>
                  <% end %>
                </td>
                <td class="py-3 px-4 text-sm text-slate-600">
                  <%= visit.isp || '-' %>
                </td>
                <td class="py-3 px-4 text-sm">
                  <details class="max-w-xs">
                    <summary class="cursor-pointer text-xs text-slate-500 hover:text-slate-700 truncate">
                      <%= truncate(visit.user_agent, length: 30) %>
                    </summary>
                    <p class="mt-2 text-xs text-slate-600 break-all"><%= visit.user_agent %></p>
                  </details>
                </td>
                <td class="py-3 px-4 text-sm">
                  <% if visit.referer.present? %>
                    <a href="<%= visit.referer %>" target="_blank" class="text-xs text-blue-600 hover:underline truncate max-w-xs block">
                      <%= truncate(visit.referer, length: 40) %>
                    </a>
                  <% else %>
                    <span class="text-slate-400 text-xs">直接访问</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      
      <!-- Pagination -->
      <% if @visits.total_pages > 1 %>
        <div class="mt-6 flex justify-center">
          <%= paginate @visits %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<% def flag_emoji(country_code)
   return '🌍' if country_code.blank?
   
   flags = {
     'US' => '🇺🇸', 'CN' => '🇨🇳', 'GB' => '🇬🇧', 'DE' => '🇩🇪', 'FR' => '🇫🇷',
     'JP' => '🇯🇵', 'KR' => '🇰🇷', 'IN' => '🇮🇳', 'BR' => '🇧🇷', 'CA' => '🇨🇦',
     'AU' => '🇦🇺', 'IT' => '🇮🇹', 'ES' => '🇪🇸', 'MX' => '🇲🇽', 'RU' => '🇷🇺'
   }
   
   flags[country_code.upcase] || '🌍'
 end %>
