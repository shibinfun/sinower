<% content_for :admin_title, "保修反馈" %>

<div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-slate-50 border-b border-slate-200">
          <th class="px-6 py-4 text-sm font-semibold text-slate-700">产品类型</th>
          <th class="px-6 py-4 text-sm font-semibold text-slate-700">具体型号</th>
          <th class="px-6 py-4 text-sm font-semibold text-slate-700">姓名</th>
          <th class="px-6 py-4 text-sm font-semibold text-slate-700">日期</th>
          <th class="px-6 py-4 text-sm font-semibold text-slate-700">操作</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @warranty_inquiries.each do |inquiry| %>
          <tr class="hover:bg-slate-50 transition-colors">
            <td class="px-6 py-4 text-sm font-medium text-slate-800"><%= inquiry.product_type %></td>
            <td class="px-6 py-4 text-sm text-slate-600"><%= inquiry.model_number %></td>
            <td class="px-6 py-4 text-sm text-slate-600"><%= inquiry.name %></td>
            <td class="px-6 py-4 text-sm text-slate-500"><%= inquiry.created_at.strftime("%Y-%m-%d %H:%M") %></td>
            <td class="px-6 py-4 text-sm text-slate-600 space-x-3">
              <%= link_to "查看", admin_warranty_inquiry_path(inquiry), class: "text-blue-600 hover:text-blue-800 font-medium" %>
              <%= link_to "删除", admin_warranty_inquiry_path(inquiry), data: { turbo_method: :delete, turbo_confirm: "确定要删除这条反馈信息吗？" }, class: "text-red-500 hover:text-red-700 font-medium" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<div class="mt-8">
  <%= paginate @warranty_inquiries %>
</div>
