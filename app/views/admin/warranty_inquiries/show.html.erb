<% content_for :admin_title, "保修反馈详情" %>

<div class="mb-6 flex items-center justify-between">
  <%= link_to admin_warranty_inquiries_path, class: "inline-flex items-center text-sm font-medium text-slate-500 hover:text-blue-600 transition-colors" do %>
    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
    返回列表
  <% end %>
</div>

<div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
  <div class="p-8 border-b border-slate-100">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-slate-900"><%= @warranty_inquiry.subject %></h2>
      <span class="px-3 py-1 bg-blue-50 text-blue-600 text-xs font-bold rounded-full uppercase tracking-wider">
        <%= @warranty_inquiry.product_type %>
      </span>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="space-y-6">
        <div>
          <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">具体型号</label>
          <div class="text-slate-900 font-medium"><%= @warranty_inquiry.model_number %></div>
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">提交人</label>
          <div class="text-slate-900 font-medium"><%= @warranty_inquiry.name %></div>
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">联系电话</label>
          <div class="text-slate-900 font-medium"><%= @warranty_inquiry.phone %></div>
        </div>
        <div>
          <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">电子邮箱</label>
          <div class="text-slate-900 font-medium"><%= @warranty_inquiry.email %></div>
        </div>
      </div>
      
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">提交时间</label>
        <div class="text-slate-900 font-medium"><%= @warranty_inquiry.created_at.strftime("%Y年%m月%d日 %H:%M") %></div>
      </div>
    </div>
  </div>

  <div class="p-8 bg-slate-50">
    <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-4">具体描述</label>
    <div class="prose prose-slate max-w-none text-slate-700 leading-relaxed">
      <%= simple_format @warranty_inquiry.description %>
    </div>
  </div>
</div>
