<div class="px-4 sm:px-6 lg:px-8">
  <div class="sm:flex sm:items-start">
    <div class="mt-3 text-center sm:ml-4 sm:mt-0 sm:text-left w-full">
      <h3 class="text-2xl font-bold leading-6 text-gray-900" id="modal-title">
        <%= action_name == 'new' ? '上传新 PDF' : '编辑 PDF' %>
      </h3>
      
      <div class="mt-6">
        <%= form_with model: [:admin, @warranty_pdf], local: true, html: { multipart: true } do |f| %>
          <div class="space-y-6">
            
            <div>
              <%= f.label :name, "PDF 名称", class: "block text-sm font-medium text-gray-700" %>
              <div class="mt-1">
                <%= f.text_field :name, 
                    class: "shadow-sm focus:ring-blue-500 focus:border-blue-500 block w-full sm:text-sm border-gray-300 rounded-md p-3 border",
                    placeholder: "例如：2026 Commercial Refrigeration Warranty" %>
              </div>
              <% if @warranty_pdf.errors[:name].any? %>
                <p class="mt-2 text-sm text-red-600"><%= @warranty_pdf.errors[:name].join(", ") %></p>
              <% end %>
            </div>

            <div>
              <%= f.label :pdf_type, "PDF 类型", class: "block text-sm font-medium text-gray-700" %>
              <div class="mt-1">
                <%= f.select :pdf_type, 
                    [
                      ['Commercial Refrigeration (商业制冷)', 'refrigeration'],
                      ['Cooking Equipment (烹饪设备)', 'cooking'],
                      ['Stainless Steel Equipment (不锈钢设备)', 'stainless'],
                      ['Submit Warranty Claim Form (索赔表单)', 'claim_form'],
                      ['Request Spare Parts Form (备件申请)', 'spare_parts']
                    ],
                    {},
                    class: "shadow-sm focus:ring-blue-500 focus:border-blue-500 block w-full sm:text-sm border-gray-300 rounded-md p-3 border" %>
              </div>
              <p class="mt-1 text-sm text-gray-500">
                选择此 PDF 对应的产品类型
              </p>
              <% if @warranty_pdf.errors[:pdf_type].any? %>
                <p class="mt-2 text-sm text-red-600"><%= @warranty_pdf.errors[:pdf_type].join(", ") %></p>
              <% end %>
            </div>

            <div>
              <%= f.label :description, "描述", class: "block text-sm font-medium text-gray-700" %>
              <div class="mt-1">
                <%= f.text_area :description, 
                    rows: 3,
                    class: "shadow-sm focus:ring-blue-500 focus:border-blue-500 block w-full sm:text-sm border-gray-300 rounded-md p-3 border",
                    placeholder: "可选，描述此 PDF 的内容或版本信息" %>
              </div>
              <% if @warranty_pdf.errors[:description].any? %>
                <p class="mt-2 text-sm text-red-600"><%= @warranty_pdf.errors[:description].join(", ") %></p>
              <% end %>
            </div>

            <div>
              <%= f.label :file, "PDF 文件", class: "block text-sm font-medium text-gray-700" %>
              <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-gray-300 border-dashed rounded-md hover:border-gray-400">
                <div class="space-y-1 text-center">
                  <% if @warranty_pdf.file.attached? %>
                    <svg class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
                      <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <div class="flex text-sm text-gray-600 justify-center">
                      <p class="pl-1">当前文件：<strong><%= @warranty_pdf.file.filename %></strong></p>
                    </div>
                    <p class="text-xs text-gray-500">
                      文件大小：<%= number_to_human_size(@warranty_pdf.file.byte_size) %>
                    </p>
                  <% else %>
                    <svg class="mx-auto h-12 w-12 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
                      <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  <% end %>
                  <div class="flex text-sm text-gray-600 justify-center">
                    <label for="file-upload" class="relative cursor-pointer bg-white rounded-md font-medium text-blue-600 hover:text-blue-500 focus-within:outline-none">
                      <span>上传文件</span>
                      <%= f.file_field :file, 
                          id: "file-upload",
                          class: "sr-only",
                          accept: "application/pdf" %>
                    </label>
                    <p class="pl-1">或拖放文件到此处</p>
                  </div>
                  <p class="text-xs text-gray-500">
                    PDF 文件，最大 10MB
                  </p>
                </div>
              </div>
              <% if @warranty_pdf.file.attached? && action_name == 'edit' %>
                <div class="mt-2">
                  <label class="inline-flex items-center">
                    <%= check_box_tag :remove_file, "1", false, 
                        class: "rounded border-gray-300 text-blue-600 shadow-sm focus:border-blue-300 focus:ring focus:ring-blue-200 focus:ring-opacity-50" %>
                    <span class="ml-2 text-sm text-gray-600">删除当前文件并上传新文件</span>
                  </label>
                </div>
              <% end %>
              <% if @warranty_pdf.errors[:file].any? %>
                <p class="mt-2 text-sm text-red-600"><%= @warranty_pdf.errors[:file].join(", ") %></p>
              <% end %>
            </div>

          </div>

          <div class="mt-6 flex items-center justify-end space-x-3">
            <%= link_to "取消", admin_warranty_pdfs_path, class: "bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50" %>
            <%= f.submit action_name == 'new' ? "上传 PDF" : "保存更改", 
                class: "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 cursor-pointer" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
  // Simple drag and drop support
  const dropZone = document.querySelector('.border-dashed');
  const fileInput = document.getElementById('file-upload');

  if (dropZone && fileInput) {
    ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
      dropZone.addEventListener(eventName, preventDefaults, false);
    });

    function preventDefaults(e) {
      e.preventDefault();
      e.stopPropagation();
    }

    ['dragenter', 'dragover'].forEach(eventName => {
      dropZone.addEventListener(eventName, () => dropZone.classList.add('border-blue-500', 'bg-blue-50'), false);
    });

    ['dragleave', 'drop'].forEach(eventName => {
      dropZone.addEventListener(eventName, () => dropZone.classList.remove('border-blue-500', 'bg-blue-50'), false);
    });

    dropZone.addEventListener('drop', (e) => {
      const dt = e.dataTransfer;
      const files = dt.files;
      if (files.length > 0) {
        fileInput.files = files;
      }
    });
  }
</script>
