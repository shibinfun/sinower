<div class="px-4 sm:px-6 lg:px-8">
  <div class="sm:flex sm:items-start">
    <div class="mt-3 text-center sm:ml-4 sm:mt-0 sm:text-left">
      <h3 class="text-2xl font-bold leading-6 text-gray-900" id="modal-title">Warranty PDF 管理</h3>
      <div class="mt-4">
        <p class="text-sm text-gray-500 mb-6">
          管理保修页面上的 PDF 文件，包括商业制冷、烹饪设备、不锈钢设备的保修 PDF 以及保修索赔表单。
        </p>
        
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center space-x-2">
            <%= link_to "返回管理面板", admin_dashboard_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
          </div>
          <%= link_to "上传新 PDF", new_admin_warranty_pdf_path, class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" %>
        </div>

        <div class="mt-6">
          <% if @warranty_pdfs.any? %>
            <div class="flex flex-col">
              <div class="-my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
                <div class="py-2 align-middle inline-block min-w-full sm:px-6 lg:px-8">
                  <div class="shadow overflow-hidden border-b border-gray-200 sm:rounded-lg">
                    <table class="min-w-full divide-y divide-gray-200">
                      <thead class="bg-gray-50">
                        <tr>
                          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                            PDF 名称
                          </th>
                          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                            类型
                          </th>
                          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                            描述
                          </th>
                          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                            文件大小
                          </th>
                          <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                            更新时间
                          </th>
                          <th scope="col" class="relative px-6 py-3">
                            <span class="sr-only">操作</span>
                          </th>
                        </tr>
                      </thead>
                      <tbody class="bg-white divide-y divide-gray-200">
                        <% @warranty_pdfs.each do |pdf| %>
                          <tr>
                            <td class="px-6 py-4 whitespace-nowrap">
                              <div class="text-sm font-medium text-gray-900"><%= pdf.name %></div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                              <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                                <%= case pdf.pdf_type
                                    when 'refrigeration' then 'bg-blue-100 text-blue-800'
                                    when 'cooking' then 'bg-orange-100 text-orange-800'
                                    when 'stainless' then 'bg-gray-100 text-gray-800'
                                    when 'claim_form' then 'bg-green-100 text-green-800'
                                    when 'spare_parts' then 'bg-purple-100 text-purple-800'
                                  end %>">
                                <%= pdf.display_name %>
                              </span>
                            </td>
                            <td class="px-6 py-4">
                              <div class="text-sm text-gray-500"><%= truncate(pdf.description, length: 50) || '-' %></div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                              <% if pdf.file.attached? %>
                                <%= number_to_human_size(pdf.file.byte_size) %>
                              <% else %>
                                <span class="text-red-500">无文件</span>
                              <% end %>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                              <%= l pdf.updated_at, format: :long rescue pdf.updated_at.strftime("%Y-%m-%d %H:%M") %>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                              <%= link_to "查看", admin_warranty_pdf_path(pdf), class: "text-indigo-600 hover:text-indigo-900 mr-3" %>
                              <%= link_to "编辑", edit_admin_warranty_pdf_path(pdf), class: "text-blue-600 hover:text-blue-900 mr-3" %>
                              <%= link_to "删除", admin_warranty_pdf_path(pdf), 
                                  method: :delete,
                                  data: { confirm: "确定要删除这个 PDF 吗？" },
                                  class: "text-red-600 hover:text-red-900" %>
                            </td>
                          </tr>
                        <% end %>
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
            </div>
          <% else %>
            <div class="text-center py-12">
              <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
              <h3 class="mt-2 text-sm font-medium text-gray-900">暂无 PDF</h3>
              <p class="mt-1 text-sm text-gray-500">上传第一个 PDF 文件开始管理。</p>
              <div class="mt-6">
                <%= link_to "上传新 PDF", new_admin_warranty_pdf_path, class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
