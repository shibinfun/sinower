<% content_for :admin_title, "导入 SKU" %>

<div class="mb-6">
  <%= link_to "返回 SKU 列表", admin_skus_path, class: "text-blue-600 hover:text-blue-800 font-medium" %>
</div>

<div class="max-w-2xl bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden p-8">
  <h2 class="text-xl font-bold text-slate-900 mb-4">上传 CSV 文件</h2>
  <p class="text-slate-600 mb-6">请选择导出的 CSV 文件进行导入。系统将根据名称和分类路径匹配 SKU，如果不存在则创建。</p>

  <%= form_with url: import_admin_skus_path, method: :post, multipart: true do |f| %>
    <div class="mb-6">
      <%= f.label :file, "选择 CSV 文件", class: "block text-sm font-medium text-slate-700 mb-2" %>
      <%= f.file_field :file, accept: ".csv", class: "block w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" %>
    </div>

    <div class="flex items-center space-x-4">
      <%= f.submit "开始导入", class: "bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg text-sm font-medium transition-colors" %>
    </div>
  <% end %>

  <div class="mt-12 p-4 bg-amber-50 rounded-lg border border-amber-200">
    <h3 class="text-sm font-bold text-amber-800 mb-2">注意事项：</h3>
    <ul class="text-xs text-amber-700 list-disc list-inside space-y-1">
      <li>确保文件格式为 CSV。</li>
      <li>“分类路径”需使用 “>” 分隔，例如：“商用冰箱 > 单门”。</li>
      <li>“频道”必须为 a, b 或 c。</li>
      <li>富文本内容请保留在 “standard_features_html” 字段中。</li>
      <li>图片 URLs 如有多个请用逗号分隔。导入过程会从 URL 下载图片。</li>
    </ul>
  </div>
</div>
