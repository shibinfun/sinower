<% content_for :admin_title, "SKU 管理" %>

<div class="mb-6 flex justify-between items-center">
  <p class="text-slate-600">管理所有的产品型号 (SKU)。注意：只能在叶子分类下创建 SKU。</p>
  <div class="flex items-center space-x-3">
    <%= link_to "添加 SKU", new_admin_sku_path, class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors" %>
  </div>
</div>

<div class="mb-6 border-b border-slate-200">
  <nav class="-mb-px flex space-x-8" aria-label="Tabs">
    <% [
      ['a', '商用制冷设备', 'Commercial Refrigeration'],
      ['b', '烹饪设备', 'Cooking Equipment'],
      ['c', '不锈钢餐饮用品', 'Stainless Steel Food Service']
    ].each do |kind, zh, en| %>
      <%= link_to admin_skus_path(kind: kind), 
          class: "whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm #{@category_kind == kind ? 'border-blue-500 text-blue-600' : 'border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300'}" do %>
        <%= zh %> <span class="text-xs text-slate-400 font-normal ml-1"><%= en %></span>
      <% end %>
    <% end %>
  </nav>
</div>

<div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="bg-slate-50 border-b border-slate-200">
          <th class="px-6 py-4 text-sm font-semibold text-slate-700">预览</th>
          <th class="px-6 py-4 text-sm font-semibold text-slate-700">名称</th>
          <th class="px-6 py-4 text-sm font-semibold text-slate-700">分类</th>
          <th class="px-6 py-4 text-sm font-semibold text-slate-700">核心规格</th>
          <th class="px-6 py-4 text-sm font-semibold text-slate-700 text-center">状态</th>
          <th class="px-6 py-4 text-sm font-semibold text-slate-700 text-right">操作</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% if @skus.empty? %>
          <tr>
            <td colspan="6" class="px-6 py-12 text-center text-slate-500 text-sm">
              该分类下暂无 SKU。
            </td>
          </tr>
        <% end %>
        <% @skus.each do |sku| %>
          <tr class="hover:bg-slate-50 transition-colors">
            <td class="px-6 py-4">
              <% if sku.images.attached? %>
                <% begin %>
                  <%= image_tag sku.images.first.variant(resize_to_limit: [50, 50]), class: "rounded-md shadow-sm" %>
                <% rescue ArgumentError, ActiveStorage::FileNotFoundError, ActiveStorage::InvariableError %>
                  <div class="w-10 h-10 bg-red-50 rounded-md flex items-center justify-center text-red-400 text-[10px] text-center" title="文件无效或非图片，请重新上传">无效</div>
                <% end %>
              <% else %>
                <div class="w-10 h-10 bg-slate-100 rounded-md flex items-center justify-center text-slate-400 text-[10px]">无图</div>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm font-medium text-slate-800"><%= sku.name %></td>
            <td class="px-6 py-4 text-sm text-slate-600"><%= sku.category.localized_name %></td>
            <td class="px-6 py-4 text-sm text-slate-600">
              <% case sku.category.category_kind %>
              <% when 'a' %>
                <span class="block">容积: <%= sku.skuable&.net_capacity %></span>
                <span class="block text-xs">温度: <%= sku.skuable&.temp_range %></span>
              <% when 'b' %>
                <span class="block">燃气: <%= sku.skuable&.gas_type %></span>
                <span class="block text-xs">热值: <%= sku.skuable&.total_btu %></span>
              <% when 'c' %>
                <span class="block">尺寸: <%= sku.skuable&.product_dimensions %></span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm text-center">
              <span class="px-2 py-1 rounded-full text-xs font-medium <%= sku.status == 'active' ? 'bg-green-100 text-green-700' : 'bg-slate-100 text-slate-700' %>">
                <%= sku.status.upcase %>
              </span>
            </td>
            <td class="px-6 py-4 text-sm text-right space-x-3">
              <%= link_to "编辑", edit_admin_sku_path(sku), class: "text-blue-600 hover:text-blue-800 font-medium" %>
              <%= link_to "删除", admin_sku_path(sku), data: { turbo_method: :delete, turbo_confirm: "确定要删除该 SKU 吗？" }, class: "text-red-500 hover:text-red-700 font-medium" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
