        <% if user_signed_in? %>
          <div class="flex items-center space-x-4">
            <span class="text-slate-300 text-sm"><%= current_user.email %></span>
            <%= button_to "Log out", destroy_user_session_path, method: :delete, class: "text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-4 py-2 text-center" %>
          </div>
        <% else %>
          <div class="flex space-x-2">
            <%= link_to "Log in", new_user_session_path, class: "text-slate-300 hover:text-white px-3 py-2 text-sm font-medium" %>
            <%= link_to "Sign up", new_user_registration_path, class: "text-white bg-blue-600 hover:bg-blue-700 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-4 py-2 text-center" %>
          </div>
        <% end %>
      </div>

      <button data-action="click->navbar#toggle" type="button" class="inline-flex items-center p-2 w-10 h-10 justify-center text-sm text-slate-400 rounded-lg md:hidden hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-slate-700" aria-controls="navbar-sticky" aria-expanded="false">
        <span class="sr-only">Open menu</span>
        <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14">
          <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/>
        </svg>
      </button>
    </div>

    <div class="items-center justify-between hidden w-full md:flex md:w-auto md:order-1" id="navbar-sticky" data-navbar-target="menu">
      <ul class="flex flex-col p-4 md:p-0 mt-4 font-medium border border-slate-800 rounded-lg bg-slate-900 md:space-x-8 rtl:space-x-reverse md:flex-row md:mt-0 md:border-0 md:bg-slate-900">
        <li>
          <%= link_to "Home", root_path, class: "block py-2 px-3 #{current_page?(root_path) ? 'text-white font-bold border-b-2 border-blue-500' : 'text-slate-300 hover:text-white'} transition-all duration-300 rounded-sm md:bg-transparent md:p-0" %>
        </li>
        <li>
          <%= link_to "About Us", about_path, class: "block py-2 px-3 #{current_page?(about_path) ? 'text-white font-bold border-b-2 border-blue-500' : 'text-slate-300 hover:text-white'} transition-all duration-300 rounded-sm md:bg-transparent md:p-0" %>
        </li>

        <% [ ['Refrigeration', 'a'], ['Cooking', 'b'], ['Foodservice', 'c'] ].each do |label, kind| %>
          <li class="relative group" data-navbar-target="rootDropdown">
            <div class="flex items-center">
              <%= link_to label, send("#{kind}_channel_path"), class: "block py-2 px-3 #{params[:kind] == kind ? 'text-white font-bold border-b-2 border-blue-500' : 'text-slate-300 hover:text-white'} transition-all duration-300 rounded-sm md:bg-transparent md:p-0 flex-grow" %>
              <button type="button" data-action="click->navbar#toggleMobileRoot" class="ml-auto text-slate-400 p-2 focus:outline-none">
                <svg class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
              </button>
            </div>
            
            <!-- Desktop/Mobile Dropdown -->
            <div class="hidden md:absolute md:left-0 md:top-full w-full md:w-64 z-50 pt-2 animate-fade-in-right dropdown-container">
              <div class="bg-slate-800 border border-slate-700 rounded-2xl shadow-2xl overflow-visible backdrop-blur-xl bg-opacity-95 py-2 ring-1 ring-white/10">
                <% categories_for_kind(kind).each do |cat| %>
                  <%= render 'layouts/navbar_category', category: cat, kind: kind %>
                <% end %>
              </div>
            </div>
          </li>
        <% end %>

        <li>
          <%= link_to "Warranty", warranty_path, class: "block py-2 px-3 #{current_page?(warranty_path) ? 'text-white font-bold border-b-2 border-blue-500' : 'text-slate-300 hover:text-white'} transition-all duration-300 rounded-sm md:bg-transparent md:p-0" %>
        </li>
        <li>
          <%= link_to "Contact Us", contact_path, class: "block py-2 px-3 #{current_page?(contact_path) ? 'text-white font-bold border-b-2 border-blue-500' : 'text-slate-300 hover:text-white'} transition-all duration-300 rounded-sm md:bg-transparent md:p-0" %>
        </li>
        <% if user_signed_in? && current_user.admin? %>
          <li>
            <a href="<%= admin_root_path %>" class="block py-2 px-3 text-yellow-400 font-bold hover:text-yellow-300 transition-all duration-300 rounded-sm md:bg-transparent md:p-0 border-b-2 border-transparent hover:border-yellow-400">Admin</a>
          </li>
        <% end %>
        <li class="md:hidden pt-4 border-t border-slate-800 mt-2">
          <% if user_signed_in? %>
            <div class="flex flex-col space-y-3">
              <span class="text-slate-300 text-sm px-3"><%= current_user.email %></span>
              <%= button_to "Log out", destroy_user_session_path, method: :delete, class: "text-white bg-blue-700 hover:bg-blue-800 font-medium rounded-lg text-sm px-4 py-2 text-center w-full" %>
            </div>
          <% else %>
            <div class="flex flex-col space-y-2">
              <%= link_to "Log in", new_user_session_path, class: "text-slate-300 hover:text-white px-3 py-2 text-sm font-medium" %>
              <%= link_to "Sign up", new_user_registration_path, class: "text-white bg-blue-600 hover:bg-blue-700 font-medium rounded-lg text-sm px-4 py-2 text-center" %>
            </div>
          <% end %>
        </li>
      </ul>
    </div>
  </div>
</nav>
