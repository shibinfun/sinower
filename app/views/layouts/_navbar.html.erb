  <nav class="bg-slate-900/90 backdrop-blur-md border-b border-white/5 fixed w-full z-30 top-0 start-0" data-controller="navbar">
  <div class="max-w-screen-xl flex flex-wrap items-center justify-between mx-auto p-4">
