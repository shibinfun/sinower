              </div>
              
              <div class="flex items-center space-x-4 pt-2">
                <div class="flex items-center space-x-2">
                  <%= link_to "EN", url_for(locale: :en), class: "text-[10px] font-black tracking-tighter #{I18n.locale == :en ? 'text-blue-500' : 'text-slate-400'}" %>
                  <span class="text-white/20">|</span>
                  <%= link_to "中文", url_for(locale: 'zh-CN'), class: "text-[10px] font-black tracking-tighter #{I18n.locale == :"zh-CN" ? 'text-blue-500' : 'text-slate-400'}" %>
