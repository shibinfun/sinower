                </div>
                <div>
                  <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest leading-none mb-1"><%= t('navbar.signed_in_as', default: 'Signed in as') %></p>
                  <p class="text-xs text-white font-bold truncate"><%= current_user.email %></p>
