                <span class="text-white/20">|</span>
                <%= link_to "中文", url_for(locale: 'zh-CN'), class: "text-[10px] font-black tracking-tighter #{I18n.locale == :"zh-CN" ? 'text-blue-500' : 'text-slate-400'}" %>
              </div>
              <div class="flex flex-col space-y-2">
