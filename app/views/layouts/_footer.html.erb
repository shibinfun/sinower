<footer class="bg-slate-900 border-t border-white/5 mt-auto">
    <div class="mx-auto w-full max-w-screen-xl p-4 py-6 lg:py-8">
        <div class="md:flex md:justify-between">
      <div class="mb-6 md:mb-0">
        <a href="<%= root_path %>" class="flex items-center">
          <%= image_tag "logo.avif", class: "h-10 w-auto", alt: "Sinower Logo" %>
        </a>
        <p class="mt-2 text-sm text-slate-400"><%= t('footer.company_desc') %></p>
      </div>
      <div class="grid grid-cols-2 gap-8 sm:gap-6 sm:grid-cols-3">
        <div>
          <h2 class="mb-6 text-sm font-semibold text-white uppercase"><%= t('footer.quick_links') %></h2>
          <ul class="text-slate-400 font-medium text-sm space-y-4">
            <li><%= link_to t('navbar.about_us'), about_path, class: "hover:underline" %></li>
            <li><%= link_to t('navbar.warranty'), warranty_path, class: "hover:underline" %></li>
            <li><%= link_to t('navbar.contact_us'), contact_path, class: "hover:underline" %></li>
          </ul>
        </div>
        <div>
          <h2 class="mb-6 text-sm font-semibold text-white uppercase"><%= t('footer.contact_us') %></h2>
          <ul class="text-slate-400 font-medium text-sm space-y-3">
            <li class="flex items-start">
              <svg class="w-4 h-4 mr-2 mt-0.5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
              <span>6155 A Jimmy Carter Blvd Suite A,<br/>Norcross, GA 30071</span>
            </li>
            <li class="flex items-center">
              <svg class="w-4 h-4 mr-2 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              <span>1 (470) 392-7672</span>
            </li>
            <li class="flex items-center">
              <svg class="w-4 h-4 mr-2 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              <span>info@sinowerus.com</span>
            </li>
          </ul>
        </div>
        <div>
          <h2 class="mb-6 text-sm font-semibold text-white uppercase">Support</h2>
          <ul class="text-slate-400 font-medium text-sm space-y-3">
            <li class="flex items-center">
              <svg class="w-4 h-4 mr-2 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              <span>support@sinowerus.com</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
      <hr class="my-6 border-slate-800 sm:mx-auto lg:my-8" />
      <div class="sm:flex sm:items-center sm:justify-between">
          <span class="text-sm text-slate-400 sm:text-center">© 2026 <a href="<%= root_path %>" class="hover:underline">Sinower™</a>. <%= t('footer.rights_reserved') %>
          </span>
      </div>
    </div>
</footer>
